# Import categories from shared module
try:
    from mactrace_categories import get_category, get_categories_for_display, CATEGORY_ORDER
except ImportError:
    # Fallback if module not found
    def get_category(syscall):
        return 'other'
    def get_categories_for_display():
        return ['file', 'network', 'process', 'memory', 'signal', 'other']
    CATEGORY_ORDER = ['file', 'network', 'process', 'memory', 'signal', 'other']


class MacTraceAnalyzer:
    """Analyze mactrace JSON output."""

    def __init__(self, save_io_dir: str = None, save_all_io: bool = False,
                 hexdump: bool = False, render_terminal_output: bool = False):
        self.save_io_dir = save_io_dir
        self.save_all_io = save_all_io
        self.hexdump = hexdump
        self.render_terminal_output = render_terminal_output
        
        self.trace_data: Dict[str, Any] = {}
        self.files: Dict[str, FileAccess] = {}
        self.fd_to_path: Dict[int, Dict[int, str]] = defaultdict(dict)  # pid -> {fd -> path}
        self.sockets: Dict[int, Dict[int, NetworkConnection]] = defaultdict(dict)  # pid -> {fd -> conn}
        self.processes: Dict[int, ProcessInfo] = {}
        self.errors: List[Dict[str, Any]] = []
        self.syscall_counts: Dict[str, int] = defaultdict(int)
        self.category_counts: Dict[str, int] = defaultdict(int)
        self.io_records: List[IORecord] = []
        self.current_seq: int = 0  # Current event sequence number
        
    def load(self, filepath: str) -> None:
        """Load trace data from file or stdin."""
        if filepath == '-':
            self.trace_data = json.load(sys.stdin)
        else:
            with open(filepath, 'r') as f:
                self.trace_data = json.load(f)
                
    def analyze(self) -> None:
        """Analyze the loaded trace data."""
        # Initialize root process
        target_pid = self.trace_data.get('target_pid', 0)
        if target_pid:
            self.processes[target_pid] = ProcessInfo(
                pid=target_pid,
                exec_path=self.trace_data.get('command', [None])[0] if self.trace_data.get('command') else None
            )
        
        # Process tree
        for child_str, parent in self.trace_data.get('process_tree', {}).items():
            child = int(child_str)
            if child not in self.processes:
                self.processes[child] = ProcessInfo(pid=child)
            self.processes[child].parent_pid = parent
            
        # Process events
        for event in self.trace_data.get('process_events', []):
            self._process_event(event)
            
        # Syscall events
        for seq, event in enumerate(self.trace_data.get('events', [])):
            self.current_seq = seq
            self._process_syscall(event)
            
    def _process_event(self, event: Dict[str, Any]) -> None:
        """Process a process lifecycle event."""
        event_type = event.get('event_type', '')
        pid = event.get('pid', 0)
        details = event.get('details', {})
        
        if pid not in self.processes:
            self.processes[pid] = ProcessInfo(pid=pid)
        proc = self.processes[pid]
        
        if event_type in ('fork', 'child_detected'):
            # parent_pid may be in details or at top level of event
            proc.parent_pid = details.get('parent_pid') or event.get('parent_pid')
            proc.fork_time = event.get('timestamp_us')
            
        elif event_type == 'exec':
            proc.exec_path = details.get('path')
            proc.exec_time = event.get('timestamp_us')
            
        elif event_type == 'exit':
            proc.exit_code = details.get('exit_code')
            proc.exit_time = event.get('timestamp_us')
            
    def _process_syscall(self, event: Dict[str, Any]) -> None:
        """Process a syscall event."""
        syscall = event.get('syscall', '')
        pid = event.get('pid', 0)
        args = event.get('args', {})
        retval = event.get('return_value', 0)
        errno = event.get('errno', 0)
        
        # Count syscalls
        self.syscall_counts[syscall] += 1
        
        # Get category from event (mactrace includes it) or fall back to lookup
        category = event.get('category') or get_category(syscall)
        self.category_counts[category] += 1
            
        # Track errors
        if errno != 0:
            error_name = args.get('errno_name', f'errno={errno}')
            self.errors.append({
                'syscall': syscall,
                'pid': pid,
                'errno': errno,
                'errno_name': error_name,
                'args': args,
            })
            
        # Handle specific syscalls
        if syscall in ('open', 'open_nocancel', 'openat', 'openat_nocancel'):
            self._handle_open(pid, syscall, args, retval, errno)
        elif syscall in ('close', 'close_nocancel'):
            self._handle_close(pid, args, retval)
        elif syscall in ('read', 'read_nocancel', 'pread', 'pread_nocancel'):
            self._handle_read(pid, args, retval)
        elif syscall in ('write', 'write_nocancel', 'pwrite', 'pwrite_nocancel'):
            self._handle_write(pid, args, retval)
        elif syscall in ('stat64', 'lstat64', 'fstat64', 'fstatat64', 'access', 'faccessat'):
            self._handle_stat(pid, syscall, args, errno)
        elif syscall == 'socket':
            self._handle_socket(pid, args, retval)
        elif syscall in ('connect', 'connect_nocancel'):
            self._handle_connect(pid, args, retval, errno)
        elif syscall in ('bind',):
            self._handle_bind(pid, args, retval)
        elif syscall in ('sendto', 'sendto_nocancel'):
            self._handle_send(pid, args, retval)
        elif syscall in ('recvfrom', 'recvfrom_nocancel'):
            self._handle_recv(pid, args, retval)
        elif syscall in ('execve', 'posix_spawn', '__mac_execve'):
            self._handle_exec(pid, syscall, args, retval, errno)
            
    def _handle_exec(self, pid: int, syscall: str, args: Dict, retval: int, errno: int) -> None:
        """Handle exec syscalls to track process exec paths."""
        if errno != 0:
            return  # Failed exec, don't update path
        
        path = args.get('path', '')
        if not path:
            return
            
        # For posix_spawn, the child pid might be different - it's in retval
        # But usually we track by current pid
        if pid not in self.processes:
            self.processes[pid] = ProcessInfo(pid=pid)
        
        self.processes[pid].exec_path = path
            
    def _handle_open(self, pid: int, syscall: str, args: Dict, retval: int, errno: int) -> None:
        """Handle open/openat syscalls."""
        path = args.get('path', '')
        if not path:
            return
            
        if path not in self.files:
            self.files[path] = FileAccess(
                path=path,
                is_config=is_config_file(path),
                is_library=is_library(path),
                is_startup=is_startup_file(path),
            )
            
        fa = self.files[path]
        fa.pids.add(pid)
        
        if errno == 0 and retval >= 0:
            fa.opened = True
            self.fd_to_path[pid][retval] = path
            
            # Check flags for read/write intent
            flags = args.get('flags', '')
            if isinstance(flags, str):
                if 'O_WRONLY' in flags or 'O_RDWR' in flags:
                    fa.written = True
                if 'O_RDONLY' in flags or 'O_RDWR' in flags:
                    fa.read = True
        else:
            fa.error = args.get('errno_name', f'errno={errno}')
            
    def _handle_close(self, pid: int, args: Dict, retval: int) -> None:
        """Handle close syscalls."""
        fd = args.get('fd')
        if fd is not None and fd in self.fd_to_path.get(pid, {}):
            path = self.fd_to_path[pid].pop(fd)
            if path in self.files:
                self.files[path].closed = True
                
    def _handle_read(self, pid: int, args: Dict, retval: int) -> None:
        """Handle read syscalls."""
        fd = args.get('fd')
        if fd is not None and retval > 0:
            # Check if this is a socket first (read/write on sockets is network I/O)
            if fd in self.sockets.get(pid, {}):
                self.sockets[pid][fd].bytes_recv += retval
                if self.save_io_dir and 'data' in args:
                    target = self._get_socket_target(pid, fd)
                    self._record_io(pid, fd, 'recv', target, args['data'])
            else:
                # File I/O
                path = self.fd_to_path.get(pid, {}).get(fd)
                if path and path in self.files:
                    self.files[path].read = True
                    self.files[path].bytes_read += retval
                if self.save_io_dir and 'data' in args:
                    # Record I/O even for stdin/unknown fds
                    target = path if path else None
                    self._record_io(pid, fd, 'read', target, args['data'])
                
    def _handle_write(self, pid: int, args: Dict, retval: int) -> None:
        """Handle write syscalls."""
        fd = args.get('fd')
        if fd is not None and retval > 0:
            # Check if this is a socket first (read/write on sockets is network I/O)
            if fd in self.sockets.get(pid, {}):
                self.sockets[pid][fd].bytes_sent += retval
                if self.save_io_dir and 'data' in args:
                    target = self._get_socket_target(pid, fd)
                    self._record_io(pid, fd, 'send', target, args['data'])
            else:
                # File I/O
                path = self.fd_to_path.get(pid, {}).get(fd)
                if path and path in self.files:
                    self.files[path].written = True
                    self.files[path].bytes_written += retval
                if self.save_io_dir and 'data' in args:
                    # Record I/O even for stdout/stderr/unknown fds
                    target = path if path else None
                    self._record_io(pid, fd, 'write', target, args['data'])
                
    def _handle_stat(self, pid: int, syscall: str, args: Dict, errno: int) -> None:
        """Handle stat/access syscalls."""
        path = args.get('path', '')
        if not path:
            # fstat64 uses fd instead
            return
            
        if path not in self.files:
            self.files[path] = FileAccess(
                path=path,
                is_config=is_config_file(path),
                is_library=is_library(path),
                is_startup=is_startup_file(path),
            )
            
        fa = self.files[path]
        fa.pids.add(pid)
        fa.stat = True
        
        if errno != 0:
            fa.error = args.get('errno_name', f'errno={errno}')
            
    def _handle_socket(self, pid: int, args: Dict, retval: int) -> None:
        """Handle socket syscalls."""
        if retval < 0:
            return
            
        domain = args.get('domain', 'unknown')
        sock_type = args.get('type', 'unknown')
        
        conn = NetworkConnection(
            fd=retval,
            family=domain,
            sock_type=sock_type,
            pid=pid,
        )
        self.sockets[pid][retval] = conn
        
    def _handle_connect(self, pid: int, args: Dict, retval: int, errno: int) -> None:
        """Handle connect syscalls."""
        fd = args.get('fd')
        if fd is None:
            return
            
        if fd in self.sockets.get(pid, {}):
            conn = self.sockets[pid][fd]
            if errno == 0 or errno == 36:  # EINPROGRESS
                conn.connected = True
                
    def _handle_bind(self, pid: int, args: Dict, retval: int) -> None:
        """Handle bind syscalls."""
        fd = args.get('fd')
        if fd is None:
            return
            
        if fd in self.sockets.get(pid, {}):
            conn = self.sockets[pid][fd]
            # TODO: parse address when available
            
    def _handle_send(self, pid: int, args: Dict, retval: int) -> None:
        """Handle sendto syscalls."""
        fd = args.get('fd')
        if fd is not None and retval > 0:
            if fd in self.sockets.get(pid, {}):
                self.sockets[pid][fd].bytes_sent += retval
            # Record I/O if data is available
            if self.save_io_dir and 'data' in args:
                target = self._get_socket_target(pid, fd)
                self._record_io(pid, fd, 'send', target, args['data'])
                
    def _handle_recv(self, pid: int, args: Dict, retval: int) -> None:
        """Handle recvfrom syscalls."""
        fd = args.get('fd')
        if fd is not None and retval > 0:
            if fd in self.sockets.get(pid, {}):
                self.sockets[pid][fd].bytes_recv += retval
            # Record I/O if data is available
            if self.save_io_dir and 'data' in args:
                target = self._get_socket_target(pid, fd)
                self._record_io(pid, fd, 'recv', target, args['data'])

    def _get_socket_target(self, pid: int, fd: int) -> str:
        """Get descriptive target string for a socket."""
        if fd in self.sockets.get(pid, {}):
            conn = self.sockets[pid][fd]
            parts = [conn.family, conn.sock_type]
            if conn.remote_addr:
                parts.append(conn.remote_addr)
            return '-'.join(str(p) for p in parts if p and p != 'unknown')
        return f"socket-fd{fd}"

    def _get_program_name(self, pid: int, visited: set = None) -> str:
        """Get program name for a pid, inheriting from parent if forked without exec."""
        if visited is None:
            visited = set()
        
        if pid in visited:
            return "unknown"  # Avoid infinite recursion
        visited.add(pid)
        
        proc = self.processes.get(pid)
        if not proc:
            return "unknown"
        
        if proc.exec_path:
            return os.path.basename(proc.exec_path)
        
        # Inherit from parent (forked process runs same binary)
        if proc.parent_pid and proc.parent_pid in self.processes:
            return self._get_program_name(proc.parent_pid, visited)
        
        return "unknown"

    def _record_io(self, pid: int, fd: int, operation: str, target: str, data) -> None:
        """Record an I/O operation for later saving."""
        if not target:
            target = f"fd{fd}"
        
        # Determine if this is a startup file
        is_startup = is_startup_file(target) if target else False
        
        # Handle stdin/stdout/stderr
        if fd in (0, 1, 2):
            fd_names = {0: 'stdin', 1: 'stdout', 2: 'stderr'}
            target = fd_names.get(fd, target)
            is_startup = False
        
        # Get program name (inherit from parent if forked without exec)
        program = self._get_program_name(pid)
        
        # Extract raw bytes
        raw_bytes = extract_raw_bytes(data)
        
        if raw_bytes:
            record = IORecord(
                pid=pid,
                program=program,
                operation=operation,
                target=target,
                data=raw_bytes,
                is_startup=is_startup,
                seq=self.current_seq,
                fd=fd,
            )
            self.io_records.append(record)

    def save_io_files(self) -> Dict[str, Any]:
        """
        Save recorded I/O to files.
        
        Returns a dict with statistics about saved files.
        """
        import subprocess
        
        if not self.save_io_dir:
            return {}
        
        os.makedirs(self.save_io_dir, exist_ok=True)
        
        # Group records by (pid, program, operation, target)
        grouped = defaultdict(list)
        for record in self.io_records:
            if not self.save_all_io and record.is_startup:
                continue
            key = (record.pid, record.program, record.operation, record.target)
            grouped[key].append(record)
        
        stats = {
            'files_saved': 0,
            'total_bytes': 0,
            'skipped_startup': 0,
            'files': []
        }
        
        if not self.save_all_io:
            stats['skipped_startup'] = sum(1 for r in self.io_records if r.is_startup)
        
        for (pid, program, operation, target), records in grouped.items():
            safe_program = sanitize_filename(program, max_len=20)
            safe_target = sanitize_filename(target, max_len=40)
            filename = f"{pid}-{safe_program}-{operation}-{safe_target}.bin"
            filepath = os.path.join(self.save_io_dir, filename)
            
            # Handle collisions
            base_filepath = filepath
            seq = 1
            while os.path.exists(filepath):
                name, ext = os.path.splitext(base_filepath)
                filepath = f"{name}.{seq}{ext}"
                seq += 1
            
            # Combine data and track offsets
            combined_data = b''
            offset_map = []
            for r in records:
                offset_map.append({
                    'offset': len(combined_data),
                    'length': len(r.data),
                    'seq': r.seq
                })
                combined_data += r.data
            
            # Write binary file
            with open(filepath, 'wb') as f:
                f.write(combined_data)
            
            # Write metadata
            meta_filepath = filepath + '.meta.json'
            with open(meta_filepath, 'w') as f:
                json.dump({'offsets': offset_map, 'total_size': len(combined_data)}, f)
            
            stats['files_saved'] += 1
            stats['total_bytes'] += len(combined_data)
            stats['files'].append({
                'path': filepath,
                'size': len(combined_data),
                'operation': operation,
                'target': target,
                'pid': pid,
                'program': program
            })
            
            # Create hexdump if requested
            if self.hexdump:
                try:
                    result = subprocess.run(
                        ['hexdump', '-C', filepath],
                        capture_output=True,
                        timeout=30
                    )
                    if result.returncode == 0 and result.stdout:
                        hexdump_filepath = filepath + '.hexdump'
                        with open(hexdump_filepath, 'wb') as f:
                            f.write(result.stdout)
                except (subprocess.TimeoutExpired, FileNotFoundError):
                    pass
            
            # Create rendered version if requested
            if self.render_terminal_output:
                rendered_data = render_terminal(combined_data)
                if rendered_data != combined_data:
                    rendered_filepath = filepath + '.rendered'
                    with open(rendered_filepath, 'wb') as f:
                        f.write(rendered_data)
        
        return stats

