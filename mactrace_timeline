class TimelineGenerator:
    """Generate HTML timeline from mactrace JSON data."""

    def __init__(self, input_file: str = None, output_dir: str = None):
        self.input_file = input_file or "stdin"
        self.output_dir = output_dir
        self.trace_data: Dict[str, Any] = {}
        # pid -> {fd -> target_info}
        self.fd_map: Dict[int, Dict[int, Dict]] = defaultdict(dict)
        # Scan I/O files if output_dir provided
        self.io_files: Dict[str, List[Dict]] = {}

    def load(self, filepath: str) -> None:
        """Load trace data from file or stdin."""
        if filepath == '-':
            self.trace_data = json.load(sys.stdin)
        else:
            with open(filepath, 'r') as f:
                self.trace_data = json.load(f)
        
        if self.output_dir:
            self.io_files = self._scan_io_files()

    def _scan_io_files(self) -> Dict[str, List[Dict]]:
        """Scan output directory for I/O files."""
        files = defaultdict(list)
        if not self.output_dir or not os.path.isdir(self.output_dir):
            return files
        
        for filename in os.listdir(self.output_dir):
            filepath = os.path.join(self.output_dir, filename)
            if not os.path.isfile(filepath):
                continue
            
            # Parse: PID-program-operation-target.bin[.hexdump|.rendered]
            is_hexdump = filename.endswith('.hexdump')
            is_rendered = filename.endswith('.rendered')
            is_bin = filename.endswith('.bin') and not is_hexdump and not is_rendered
            
            if is_bin:
                base_name = filename
            elif is_hexdump:
                base_name = filename[:-8]
            elif is_rendered:
                base_name = filename[:-9]
            else:
                continue
            
            match = re.match(r'^(\d+)-([^-]+)-(\w+)-(.+)\.bin$', base_name)
            if match:
                pid = int(match.group(1))
                program = match.group(2)
                operation = match.group(3)
                target = match.group(4)
                
                key = f"{pid}-{program}-{operation}-{target}"
                file_info = {
                    'path': filepath,
                    'filename': filename,
                    'size': os.path.getsize(filepath),
                    'pid': pid,
                    'program': program,
                    'operation': operation,
                    'target': target,
                    'type': 'bin' if is_bin else ('hexdump' if is_hexdump else 'rendered'),
                }
                files[key].append(file_info)
        
        return files

    def _find_io_files(self, pid: int, operation: str, target: str, fd: int = None) -> Dict[str, Dict]:
        """Find I/O files matching criteria."""
        result = {}
        if not self.io_files:
            return result
        
        # Build list of patterns to search for
        patterns = []
        
        if target:
            target_basename = os.path.basename(target) if '/' in target else target
            sanitized = sanitize_filename(target_basename, 40)
            patterns.append(sanitized)
            if target_basename != sanitized:
                patterns.append(target_basename)
        
        # For sockets, also try matching by family/type (how mactrace_analyze names them)
        if fd is not None:
            fd_info = self.fd_map.get(pid, {}).get(fd, {})
            if fd_info.get('type') == 'socket':
                domain = fd_info.get('domain', '')
                sock_type = fd_info.get('sock_type', '')
                if domain and sock_type:
                    socket_pattern = f"{domain}-{sock_type}"
                    patterns.append(socket_pattern)
        
        # Also check stdin/stdout/stderr
        if fd in (0, 1, 2):
            fd_names = {0: 'stdin', 1: 'stdout', 2: 'stderr'}
            patterns.append(fd_names[fd])
        
        if not patterns:
            return result
        
        # Determine operation pattern (read/recv or write/send)
        op_patterns = [f"-{operation}-"]
        if operation == 'read':
            op_patterns.append("-recv-")
        elif operation == 'write':
            op_patterns.append("-send-")
        
        # Look for matching files
        for key, files in self.io_files.items():
            if not key.startswith(f"{pid}-"):
                continue
            if not any(op in key for op in op_patterns):
                continue
            
            if any(pat in key for pat in patterns):
                for f in files:
                    if f['type'] not in result:
                        result[f['type']] = f
        
        return result

    def _track_fd(self, event: Dict) -> None:
        """Track file descriptor to target mapping."""
        syscall = event.get('syscall', '')
        args = event.get('args', {})
        retval = event.get('return_value', 0)
        pid = event.get('pid', 0)
        errno = event.get('errno', 0)
        
        # File opens
        if syscall in ('open', 'open_nocancel', 'openat', 'openat_nocancel'):
            if errno == 0 and retval >= 0:
                path = args.get('path', '')
                if path:
                    self.fd_map[pid][retval] = {'type': 'file', 'path': path}
        
        # Socket creation
        elif syscall == 'socket':
            if errno == 0 and retval >= 0:
                domain = args.get('domain', 'unknown')
                sock_type = args.get('type', 'unknown')
                self.fd_map[pid][retval] = {
                    'type': 'socket',
                    'domain': domain,
                    'sock_type': sock_type,
                }
        
        # Connect - associates fd with remote address
        elif syscall in ('connect', 'connect_nocancel'):
            fd = args.get('fd')
            if fd is not None and fd in self.fd_map.get(pid, {}):
                display = args.get('display', '')
                if display:
                    self.fd_map[pid][fd]['remote'] = display
                    self.fd_map[pid][fd]['display'] = display
        
        # Bind - associates fd with local address
        elif syscall == 'bind':
            fd = args.get('fd')
            if fd is not None and fd in self.fd_map.get(pid, {}):
                display = args.get('display', '')
                if display:
                    self.fd_map[pid][fd]['local'] = display
                    if 'display' not in self.fd_map[pid][fd]:
                        self.fd_map[pid][fd]['display'] = display
        
        # Accept - new fd with client address
        elif syscall in ('accept', 'accept_nocancel'):
            if errno == 0 and retval >= 0:
                display = args.get('display', '')
                self.fd_map[pid][retval] = {
                    'type': 'socket',
                    'remote': display,
                    'display': display or f'client-fd{retval}',
                }
        
        # Close
        elif syscall in ('close', 'close_nocancel'):
            fd = args.get('fd')
            if fd is not None and fd in self.fd_map.get(pid, {}):
                del self.fd_map[pid][fd]

    def _get_fd_target(self, pid: int, fd: int) -> str:
        """Get the target (path/address) for an fd."""
        # Handle stdin/stdout/stderr
        if fd == 0:
            return "stdin"
        elif fd == 1:
            return "stdout"
        elif fd == 2:
            return "stderr"
        
        info = self.fd_map.get(pid, {}).get(fd, {})
        if 'display' in info:
            return info['display']
        if 'path' in info:
            return info['path']
        return f"fd={fd}"

    def _extract_target(self, event: Dict) -> str:
        """Extract the primary target from a syscall event."""
        syscall = event.get('syscall', '')
        args = event.get('args', {})
        pid = event.get('pid', 0)
        
        # Socket address from connect/bind/accept/sendto/recvfrom
        if 'display' in args:
            return args['display']
        
        # File path
        if 'path' in args:
            return args['path']
        
        # fd-based operations - look up the target
        if 'fd' in args:
            fd = args['fd']
            return self._get_fd_target(pid, fd)
        
        # Socket creation
        if syscall == 'socket':
            domain = args.get('domain', '?')
            sock_type = args.get('type', '?')
            return f"{domain}/{sock_type}"
        
        return ""

    def _extract_details(self, event: Dict) -> str:
        """Extract additional details from a syscall event."""
        syscall = event.get('syscall', '')
        args = event.get('args', {})
        retval = event.get('return_value', 0)
        
        parts = []
        
        # Socket family (if not in target)
        if 'family' in args and 'display' not in args:
            parts.append(args['family'])
        
        # Flags for open
        if 'flags' in args and syscall in ('open', 'openat', 'open_nocancel', 'openat_nocancel'):
            parts.append(args['flags'])
        
        # Count for read/write
        if 'count' in args:
            parts.append(f"count={args['count']}")
        
        # Return value info
        if syscall in ('read', 'write', 'pread', 'pwrite', 'sendto', 'recvfrom') and retval > 0:
            parts.append(f"→ {format_bytes(retval)}")
        elif syscall in ('open', 'openat', 'socket') and retval >= 0:
            parts.append(f"→ fd={retval}")
        elif syscall == 'accept' and retval >= 0:
            parts.append(f"→ fd={retval}")
        elif syscall == 'connect' and retval == 0:
            parts.append("→ connected")
        
        return " ".join(parts)

    def _is_io_syscall(self, syscall: str) -> bool:
        """Check if syscall is an I/O operation."""
        base = syscall.replace('_nocancel', '')
        return base in ('read', 'pread', 'write', 'pwrite', 
                       'sendto', 'recvfrom', 'sendmsg', 'recvmsg')

    def _generate_analysis(self) -> Dict[str, Any]:
        """Generate analysis summary."""
        events = self.trace_data.get('events', [])
        cmd = self.trace_data.get('command', [])
        duration = self.trace_data.get('duration_ms', 0)
        target_pid = self.trace_data.get('target_pid', 0)
        exit_code = self.trace_data.get('exit_code', 0)
        syscall_count = len(events)
        
        cat_counts = Counter()
        syscall_counts = Counter()
        files_read = set()
        files_written = set()
        errors = []
        
        for event in events:
            category = event.get('category') or get_category(event.get('syscall', ''))
            cat_counts[category] += 1
            syscall_counts[event.get('syscall', '')] += 1
            
            args = event.get('args', {})
            syscall = event.get('syscall', '')
            errno = event.get('errno', 0)
            
            path = args.get('path', '')
            if path:
                if syscall in ('open', 'openat', 'open_nocancel', 'openat_nocancel'):
                    flags = args.get('flags_raw', 0)
                    if errno == 0:
                        if flags & 0x3 in (0, 2):
                            files_read.add(path)
                        if flags & 0x3 in (1, 2):
                            files_written.add(path)
            
            if errno != 0:
                errno_name = args.get('errno_name', f'E{errno}')
                errors.append({
                    'syscall': syscall,
                    'errno': errno,
                    'errno_name': errno_name,
                    'target': path or args.get('fd', ''),
                })
        
        return {
            'command': ' '.join(cmd),
            'duration_ms': duration,
            'target_pid': target_pid,
            'exit_code': exit_code,
            'syscall_count': syscall_count,
            'cat_counts': dict(cat_counts),
            'syscall_counts': dict(syscall_counts.most_common(10)),
            'files_read': sorted(files_read)[:20],
            'files_written': sorted(files_written)[:10],
            'errors': errors[:20],
            'error_count': len(errors),
        }

    def _render_analysis_html(self, analysis: Dict[str, Any]) -> str:
        """Render analysis summary as HTML."""
        lines = []
        
        lines.append(f"<strong>Command:</strong> {html.escape(analysis['command'])}")
        
        ms = analysis['duration_ms']
        dur_str = f"{ms:.1f}ms" if ms < 1000 else f"{ms/1000:.2f}s"
        
        lines.append(f"<strong>Duration:</strong> {dur_str} | "
                    f"<strong>PID:</strong> {analysis['target_pid']} | "
                    f"<strong>Exit:</strong> {analysis['exit_code']} | "
                    f"<strong>Syscalls:</strong> {analysis['syscall_count']}")
        
        if analysis['syscall_counts']:
            lines.append("")
            lines.append("<strong>Top Syscalls:</strong> " + 
                        ", ".join(f"{k}({v})" for k, v in analysis['syscall_counts'].items()))
        
        if analysis['files_read']:
            lines.append("")
            lines.append("<strong>Files Read:</strong>")
            for f in analysis['files_read'][:10]:
                lines.append(f"  {html.escape(f)}")
        
        if analysis['files_written']:
            lines.append("")
            lines.append("<strong>Files Written:</strong>")
            for f in analysis['files_written'][:5]:
                lines.append(f"  {html.escape(f)}")
        
        if analysis['errors']:
            lines.append("")
            lines.append(f"<strong>Errors ({len(analysis['errors'])}):</strong>")
            for err in analysis['errors'][:10]:
                lines.append(f"  {err['syscall']}: {err['errno_name']} on {html.escape(str(err['target']))}")
        
        return "<br>".join(lines)

    def generate(self, max_rows: int = None) -> str:
        """Generate HTML timeline."""
        events = self.trace_data.get('events', [])
        
        # Apply max_rows limit if specified
        if max_rows and len(events) > max_rows:
            events = events[:max_rows]
        
        # First pass: track fd mappings
        for event in events:
            self._track_fd(event)
        
        # Reset for second pass
        self.fd_map = defaultdict(dict)
        
        # Build table rows
        rows = []
        for idx, event in enumerate(events):
            self._track_fd(event)
            
            seq = event.get('timestamp_us', idx)
            pid = event.get('pid', 0)
            syscall = event.get('syscall', '')
            retval = event.get('return_value', 0)
            errno = event.get('errno', 0)
            args = event.get('args', {})
            
            category = event.get('category') or get_category(syscall)
            target = self._extract_target(event)
            details = self._extract_details(event)
            
            # Check for I/O data
            has_io_data = 'data' in args
            is_io = self._is_io_syscall(syscall)
            io_files = {}
            if is_io and retval > 0:
                op = 'read' if 'read' in syscall or 'recv' in syscall else 'write'
                fd = args.get('fd')
                io_files = self._find_io_files(pid, op, target, fd)
            
            errno_name = args.get('errno_name', '')
            if errno != 0:
                result = f'<span class="error">{retval} ({errno_name})</span>'
            else:
                result = str(retval)
            
            rows.append({
                'seq': seq,
                'pid': pid,
                'syscall': syscall,
                'category': category,
                'result': result,
                'result_raw': retval,
                'target': target,
                'details': details,
                'is_error': errno != 0,
                'is_io': is_io and retval > 0,
                'has_io_data': has_io_data,
                'io_files': io_files,
                'io_size': retval if is_io and retval > 0 else 0,
            })
        
        return self._render_html(rows)

