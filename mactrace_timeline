            if (e.target.classList.contains('io-link')) {{
                e.stopPropagation();
                const io = JSON.parse(e.target.dataset.io);
                let html = '';
                if (io.bin) html += '<a href="' + escapeHtml(io.bin.f) + '" target="_blank">Raw (' + formatBytes(io.bin.s) + ')</a>';
                if (io.hexdump) html += '<a href="' + escapeHtml(io.hexdump.f) + '" target="_blank">Hexdump</a>';
                if (io.rendered) html += '<a href="' + escapeHtml(io.rendered.f) + '" target="_blank">Rendered</a>';
                ioMenu.innerHTML = html;
                const rect = e.target.getBoundingClientRect();
                ioMenu.style.left = rect.left + 'px';
                ioMenu.style.top = (rect.bottom + 2) + 'px';
                ioMenu.classList.add('show');
            }} else {{
                ioMenu.classList.remove('show');
            }}
        }});
        
        applyFilter();
    }})();
    </script>
</body>
</html>'''

    def _render_html(self, rows: List[Dict]) -> str:
        """Render the HTML page."""
        
        analysis = self._generate_analysis()
        analysis_html = self._render_analysis_html(analysis)
        
        cmd = self.trace_data.get('command', [])
        
        # Count by category + errors
        cat_counts = defaultdict(int)
        error_count = 0
        for row in rows:
            cat_counts[row['category']] += 1
            if row['is_error']:
                error_count += 1
        
        # Generate filter buttons (categories with counts + errors)
        filter_buttons = ['<button class="filter-btn active" data-filter="all" style="background:#666;color:#fff">All</button>']
        
        for cat in CATEGORY_ORDER:
            if cat_counts.get(cat, 0) > 0:
                bg = get_color(cat)
                text = get_text_color(cat)
                label = cat.upper() if cat in ('ipc', 'mac', 'necp') else cat.capitalize()
                count = cat_counts[cat]
                filter_buttons.append(
                    f'<button class="filter-btn" data-filter="{cat}" '
                    f'style="background:{bg};color:{text}">{label} ({count})</button>'
                )
        
        if error_count > 0:
            filter_buttons.append(
                f'<button class="filter-btn" data-filter="error" '
                f'style="background:#d32f2f;color:#fff">Errors ({error_count})</button>'
            )
        
        # Generate table rows
        rows_html = []
        for row in rows:
            cat_bg = get_color(row['category'])
            cat_text = get_text_color(row['category'])
            error_class = ' class="error-row"' if row['is_error'] else ''
            
            # I/O dropdown
            io_cell = ''
            if row['is_io']:
                if row['io_files']:
                    menu_items = []
                    for ftype in ['bin', 'hexdump', 'rendered']:
                        if ftype in row['io_files']:
                            finfo = row['io_files'][ftype]
                            fname = finfo['filename']
                            fsize = format_bytes(finfo['size'])
                            if ftype == 'bin':
                                menu_items.append(f'<a href="{html.escape(fname)}" target="_blank">Raw ({fsize})</a>')
                            elif ftype == 'hexdump':
                                menu_items.append(f'<a href="{html.escape(fname)}" target="_blank">Hexdump</a>')
                            else:
                                menu_items.append(f'<a href="{html.escape(fname)}" target="_blank">Rendered</a>')
                    
                    if menu_items:
                        io_cell = f'''<span class="io-dropdown">
                            <span class="io-toggle">[+]</span>
                            <span class="io-menu">{''.join(f"<span>{item}</span>" for item in menu_items)}</span>
                        </span>'''
                    else:
                        io_cell = '<span class="io-toggle io-empty" title="Use -d to link I/O files">[+]</span>'
                else:
                    io_cell = '<span class="io-toggle io-empty" title="Use -d to link I/O files">[+]</span>'
            
            rows_html.append(f'''<tr{error_class} data-category="{row['category']}">
                <td style="background:{DATA_COLORS[0]}">{row['seq']}</td>
                <td style="background:{DATA_COLORS[1]}">{row['pid']}</td>
                <td style="background:{DATA_COLORS[2]}">{io_cell}<span class="syscall-badge" style="background:{cat_bg};color:{cat_text}">{html.escape(row['syscall'])}</span></td>
                <td style="background:{DATA_COLORS[3]}">{row['result']}</td>
