def main():
    parser = argparse.ArgumentParser(
        description='Generate HTML timeline from mactrace JSON',
        epilog='Reads JSON from mactrace and generates interactive HTML timeline.'
    )
    parser.add_argument('file', help='mactrace JSON file (use - for stdin)')
    parser.add_argument('-o', '--output', required=True, help='Output HTML file')
    parser.add_argument('-d', '--output-dir', help='Directory with I/O files from mactrace_analyze.py --save-io')
    parser.add_argument('--max-rows', type=int, help='Limit output to first N rows (for huge traces)')
    parser.add_argument('--virtual', action='store_true', 
                        help='Use virtual scrolling (scales to 1M+ rows)')
    
    args = parser.parse_args()
    
    # Resolve input file path using config
    input_file = resolve_input_path(args.file)
    
    # Resolve output-dir if provided
    output_dir = args.output_dir
    if output_dir and not os.path.isabs(output_dir) and not output_dir.startswith('./'):
        mactrace_output = get_config_value('MACTRACE_OUTPUT')
        if mactrace_output:
            output_dir = os.path.join(mactrace_output, output_dir)
    
    generator = TimelineGenerator(input_file=input_file, output_dir=output_dir)
    
    try:
        generator.load(input_file)
    except FileNotFoundError:
        if input_file != args.file:
            print(f"Error: File not found: {input_file}", file=sys.stderr)
            print(f"  (resolved from: {args.file})", file=sys.stderr)
        else:
            print(f"Error: File not found: {args.file}", file=sys.stderr)
            mactrace_output = get_config_value('MACTRACE_OUTPUT')
            if mactrace_output:
                print(f"  (MACTRACE_OUTPUT={mactrace_output})", file=sys.stderr)
        sys.exit(1)
    except json.JSONDecodeError as e:
        print(f"Error: Invalid JSON in {input_file}: {e}", file=sys.stderr)
        sys.exit(1)
    
    # Check for large traces
    event_count = len(generator.trace_data.get('events', []))
    if event_count > 50000 and not args.virtual and not args.max_rows:
        print(f"Warning: Large trace ({event_count:,} events). Consider --virtual or --max-rows.", 
              file=sys.stderr)
    
    if args.virtual:
        html_content = generator.generate_virtual(max_rows=args.max_rows)
    else:
        html_content = generator.generate(max_rows=args.max_rows)
    
    # Resolve output path using MACTRACE_OUTPUT
    output_path = args.output
    if not os.path.isabs(output_path) and not output_path.startswith('./'):
        mactrace_output = get_config_value('MACTRACE_OUTPUT')
        if mactrace_output:
            os.makedirs(mactrace_output, exist_ok=True)
            output_path = os.path.join(mactrace_output, output_path)
    
    with open(output_path, 'w') as f:
        f.write(html_content)
    
    print(f"Timeline written to: {output_path}", file=sys.stderr)


if __name__ == '__main__':
    main()
