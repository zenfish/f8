    <script>
    (function() {{
        const ROW_HEIGHT = 28;
        const BUFFER = 10;
        const allRows = {json_module.dumps(rows_json)};
        const catColors = {json_module.dumps(cat_colors)};
        
        let filteredRows = allRows;
        let currentFilter = 'all';
        let searchTerm = '';
        
        const container = document.getElementById('container');
        const viewport = document.getElementById('viewport');
        const spacer = document.getElementById('spacer');
        const statusEl = document.getElementById('status');
        const ioMenu = document.getElementById('io-menu');
        
        function escapeHtml(s) {{
            if (!s) return '';
            return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }}
        
        function formatBytes(n) {{
            if (n < 1024) return n + '';
            if (n < 1024*1024) return (n/1024).toFixed(1) + 'K';
            return (n/(1024*1024)).toFixed(1) + 'M';
        }}
        
        function renderRow(r) {{
            const [seq, pid, syscall, cat, result, errName, target, details, isErr, io] = r;
            const c = catColors[cat] || {{bg:'#666',text:'#fff'}};
            const errClass = isErr ? ' error' : '';
            const resultHtml = isErr ? '<span class="error-text">' + result + ' (' + errName + ')</span>' : result;
            
            let ioHtml = '';
            if (io) {{
                ioHtml = '<span class="io-link" data-io=\\'' + JSON.stringify(io).replace(/'/g, "\\\\'") + '\\'>[+]</span>';
            }}
            
            return '<div class="row' + errClass + '">' +
                '<div class="cell cell-seq">' + seq + '</div>' +
                '<div class="cell cell-pid">' + pid + '</div>' +
                '<div class="cell cell-syscall">' + ioHtml + '<span class="syscall-badge" style="background:' + c.bg + ';color:' + c.text + '">' + escapeHtml(syscall) + '</span></div>' +
                '<div class="cell cell-result">' + resultHtml + '</div>' +
                '<div class="cell cell-target">' + escapeHtml(target) + '</div>' +
                '<div class="cell cell-details">' + escapeHtml(details) + '</div>' +
                '</div>';
        }}
        
        function applyFilter() {{
            const term = searchTerm.toLowerCase();
            filteredRows = allRows.filter(r => {{
                const [seq, pid, syscall, cat, result, errName, target, details, isErr] = r;
                if (currentFilter !== 'all') {{
                    if (currentFilter === 'error' && !isErr) return false;
                    if (currentFilter !== 'error' && cat !== currentFilter) return false;
                }}
                if (term) {{
                    const text = (syscall + ' ' + target + ' ' + details).toLowerCase();
                    if (!text.includes(term)) return false;
                }}
                return true;
            }});
            spacer.style.height = (filteredRows.length * ROW_HEIGHT) + 'px';
            statusEl.textContent = filteredRows.length.toLocaleString() + ' of ' + allRows.length.toLocaleString() + ' rows';
            render();
        }}
        
        function render() {{
            const scrollTop = container.scrollTop;
            const viewHeight = container.clientHeight;
            const startIdx = Math.max(0, Math.floor(scrollTop / ROW_HEIGHT) - BUFFER);
            const endIdx = Math.min(filteredRows.length, Math.ceil((scrollTop + viewHeight) / ROW_HEIGHT) + BUFFER);
            
            viewport.style.top = (startIdx * ROW_HEIGHT + 40) + 'px';  // 40 = header height
            viewport.innerHTML = filteredRows.slice(startIdx, endIdx).map(renderRow).join('');
        }}
        
        container.addEventListener('scroll', render);
        window.addEventListener('resize', render);
        
