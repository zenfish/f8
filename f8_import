#!/bin/bash
#
# f8-import - Import trace JSON files into the f8 SQLite database
#
# Imports trace data for timeline viewing and analysis with f8-server.
#
# USAGE:
#   f8-import <trace.json> [options]
#
# OPTIONS:
#   --db <path>      Database path (default: $F8_DB or $F8_HOME/f8.db)
#   --io-dir <path>  Directory containing I/O capture files
#   --help           Show this help
#
# ENVIRONMENT:
#   F8_HOME    Base directory (default: ~/.f8)
#   F8_DB      Database path
#   F8_OUTPUT  Trace file directory (prepended to relative paths)
#
# PATH RESOLUTION:
#   - Absolute paths (/path/to/file) used as-is
#   - Explicit relative (./file, ../file) used as-is
#   - Simple filenames (trace.json) prefixed with $F8_OUTPUT
#
# EXAMPLES:
#   f8-import myapp.json              # Import from $F8_OUTPUT/myapp.json
#   f8-import ./myapp.json            # Import from current directory
#   f8-import myapp.json --io-dir io/ # Include I/O files
#

set -e

# Resolve symlinks to find actual script location
SOURCE="$0"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
SERVER_DIR="$SCRIPT_DIR/server"

# Shared config reader and path resolver
source "$SCRIPT_DIR/f8_common.sh"

# Load config before anything else
read_config

# Show help
show_help() {
    cat << 'EOF'
f8-import - Import trace JSON files into the f8 SQLite database

Imports trace data for timeline viewing and analysis with f8-server.

USAGE:
  f8-import <trace.json> [options]

OPTIONS:
  --db <path>      Database path (default: $F8_DB or $F8_HOME/f8.db)
  --io-dir <path>  Directory containing I/O capture files
  --help           Show this help

ENVIRONMENT:
  F8_HOME    Base directory (default: ~/.f8)
  F8_DB      Database path
  F8_OUTPUT  Trace file directory (prepended to relative paths)

PATH RESOLUTION:
  - Absolute paths (/path/to/file) used as-is
  - Explicit relative (./file, ../file) used as-is
  - Simple filenames (trace.json) prefixed with $F8_OUTPUT

EXAMPLES:
  f8-import myapp.json              # Import from $F8_OUTPUT/myapp.json
  f8-import ./myapp.json            # Import from current directory
  f8-import myapp.json --io-dir io/ # Include I/O files
EOF
}

if [[ "$1" == "--help" || "$1" == "-h" || -z "$1" ]]; then
    show_help
    exit 0
fi

# Resolve F8_HOME (use $HOME, not hardcoded ~)
F8_HOME="${F8_HOME:-${HOME}/.f8}"
mkdir -p "$F8_HOME"

# resolve_path is now provided by f8_common.sh (sourced above)

# Build default args from environment
env_args=()

# Database: explicit arg > F8_DB > default
if [[ ! " $* " =~ " --db " ]]; then
    db="${F8_DB:-$F8_HOME/f8.db}"
    env_args+=(--db "$db")
fi

# Process arguments, resolving paths appropriately
args=()
prev_opt=""
for arg in "$@"; do
    case "$prev_opt" in
        --io-dir)
            # I/O directory - resolve with F8_OUTPUT
            resolved=$(resolve_path "$arg" "F8_OUTPUT")
            # Make absolute for cd later
            if [[ -d "$resolved" ]]; then
                args+=("$(cd "$resolved" && pwd)")
            else
                args+=("$resolved")
            fi
            prev_opt=""
            ;;
        --db)
            # Database path - resolve with F8_HOME
            resolved=$(resolve_path "$arg" "F8_HOME")
            if [[ -e "$resolved" ]] || [[ "$arg" == /* ]] || [[ "$arg" == ./* ]] || [[ "$arg" == ../* ]]; then
                # Make absolute if it exists or is explicitly relative/absolute
                if [[ -e "$(dirname "$resolved")" ]]; then
                    args+=("$(cd "$(dirname "$resolved")" && pwd)/$(basename "$resolved")")
                else
                    args+=("$resolved")
                fi
            else
                args+=("$resolved")
            fi
            prev_opt=""
            ;;
        "")
            if [[ "$arg" == --io-dir || "$arg" == --db ]]; then
                args+=("$arg")
                prev_opt="$arg"
            elif [[ "$arg" == -* ]]; then
                # Other flags pass through
                args+=("$arg")
            else
                # Positional argument (trace file) - resolve with F8_OUTPUT
                resolved=$(resolve_path "$arg" "F8_OUTPUT")
                # Make absolute for cd later
                if [[ -e "$resolved" ]]; then
                    args+=("$(cd "$(dirname "$resolved")" && pwd)/$(basename "$resolved")")
                else
                    args+=("$resolved")
                fi
            fi
            ;;
    esac
done

cd "$SERVER_DIR"
exec node import.js "${env_args[@]}" "${args[@]}"
