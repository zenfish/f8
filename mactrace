def parse_size(size_str: str) -> int:
    """Parse a size string like '10M', '500k', '1G' into bytes."""
    size_str = size_str.strip()
    if not size_str:
        raise ValueError("Empty size string")
    
    multipliers = {
        'k': 1024,
        'm': 1024 * 1024,
        'g': 1024 * 1024 * 1024,
    }
    
    suffix = size_str[-1].lower()
    if suffix in multipliers:
        return int(float(size_str[:-1]) * multipliers[suffix])
    else:
        return int(size_str)


def render_terminal_lines(lines: List[str]) -> List[str]:
    """
    Render a list of lines as they would appear on a terminal.
    
    Handles CR (carriage return) which should move cursor to line start,
    not create a new line. This collapses progress bar updates that use
    \r to overwrite previous content.
    """
    if not lines:
        return []
    
    def is_progress_line(s: str) -> bool:
        """Check if line looks like a wget progress update."""
        stripped = s.strip()
        return (
            stripped.startswith(('0K', '1', '2', '3', '4', '5', '6', '7', '8', '9')) and
            '.....' in s
        )
    
    # Reconstruct with explicit control of line breaks
    # Lines from splitlines() that came from \r should overwrite previous
    result_lines = []
    current_line = ""
    current_is_progress = False
    
    for line in lines:
        line_is_progress = is_progress_line(line)
        
        # Progress lines only overwrite other progress lines (or empty)
        if line_is_progress and (current_is_progress or current_line == ""):
            # This progress line overwrites the current progress line
            current_line = line
            current_is_progress = True
        elif line == "" and current_line:
            # Empty line after content - could be a \r followed by nothing
            # Keep current line, don't append empty
            pass
        else:
            # Normal new line - flush current and start new
            if current_line:
                result_lines.append(current_line)
            current_line = line
            current_is_progress = line_is_progress
    
    # Don't forget the last line
    if current_line:
        result_lines.append(current_line)
    
    return result_lines


# DTrace script (loaded from template)
DTRACE_SCRIPT = r'''
/*
 * mactrace DTrace script
 * Comprehensive syscall tracing for macOS
 * Uses progenyof() for child process tracking (no proc::: probes)
 * $target_pid is replaced with $target when using dtrace -c
 */

#pragma D option quiet
#pragma D option switchrate=10hz
#pragma D option bufsize=$BUFSIZE$
#pragma D option dynvarsize=$DYNVARSIZE$
#pragma D option strsize=$STRSIZE$
$RAWIO_PRAGMA$

/*
 * TRACED predicate - matches target and all descendants
 * self->is_child flag tracks processes we've seen
 */
#define TRACED (pid == $target_pid || progenyof($target_pid) || self->is_child)

dtrace:::BEGIN
{
    printf("MACTRACE_START %d %d\n", $target_pid, walltimestamp/1000);
    /* Initialize aggregation so it exists for END */
    @all_syscalls["__init__"] = count();
}

dtrace:::END
{
    printf("MACTRACE_END %d\n", walltimestamp/1000);
    printa("MACTRACE_ALLSYSCALL %s %@d\n", @all_syscalls);
}

/* Mark child processes on first syscall */
syscall:::entry
/progenyof($target_pid) && self->is_child == 0/
{
    self->is_child = 1;
    printf("MACTRACE_CHILD %d %d %d\n", pid, ppid, walltimestamp/1000);
}

/* Count ALL syscalls for summary (to detect untraced syscalls) */
syscall:::entry
/TRACED/
{
    @all_syscalls[probefunc] = count();
}

