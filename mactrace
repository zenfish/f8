                        help=f"DTrace cleanrate - dead dynvar reclaim frequency (default: {MacTrace.DEFAULT_CLEANRATE})")
    parser.add_argument("--no-filter-wrapper", action="store_true",
                        help="Don't filter out wrapper processes (sudo/sh/bash) when using -u")
    parser.add_argument("--throttle", action="store_true",
                        help="Throttle traced program (macOS taskpolicy -b: background I/O + CPU). "
                             "Reduces DTrace drops for heavy workloads like npm install")
    parser.add_argument("--trace", type=str, default=None, metavar="SPEC",
                        help="Filter which syscall probes to load. Reduces DTrace overhead and drops. Comma-separated list of categories, aliases, or individual syscall names. Use --trace help for categories/aliases, --trace help <name> for details. Examples: --trace=net  --trace=net,process  --trace=connect,sendto,recvfrom")
    parser.add_argument("command", nargs=argparse.REMAINDER,
                        help="Command to trace. Pipelines and shell metacharacters "
                             "(|, &, ;, >, etc.) must be wrapped: "
                             "sudo mactrace sh -c 'cmd1 | cmd2'")
    
    # Handle bare --iovec-syscalls (no argument) before argparse complains
    if '--iovec-syscalls' in sys.argv and not any(
        a.startswith('--iovec-syscalls=') for a in sys.argv
    ):
        idx = sys.argv.index('--iovec-syscalls')
        # Check if next arg looks like a syscall list (not a command/flag)
        next_arg = sys.argv[idx + 1] if idx + 1 < len(sys.argv) else None
        valid_tokens = {'readv', 'writev', 'preadv', 'pwritev', 'help'}
        if not next_arg or next_arg.startswith('-') or not all(
            t.strip() in valid_tokens for t in next_arg.split(',')
        ):
