    def _parse_syscall(self, parts: List[str], base_timestamp: int) -> None:
        """Parse a syscall line"""
        # Rejoin and split more carefully to handle quoted strings
        full_line = " ".join(parts)
        
        # Basic parts: pid tid syscall retval errno
        tokens = []
        in_quote = False
        current = ""
        for char in full_line:
            if char == '"' and not in_quote:
                in_quote = True
                current += char
            elif char == '"' and in_quote:
                in_quote = False
                current += char
            elif char == ' ' and not in_quote:
                if current:
                    tokens.append(current)
                    current = ""
            else:
                current += char
        if current:
            tokens.append(current)
            
        if len(tokens) < 5:
            return
            
        try:
            pid = int(tokens[0])
            tid = int(tokens[1])
            syscall = tokens[2]
            retval = int(tokens[3]) if not tokens[3].startswith("0x") else int(tokens[3], 16)
            errno_val = int(tokens[4])
            
            self.pids_traced.add(pid)
            
            # tokens[5] is the timestamp, actual args start at tokens[6]
            # Parse syscall-specific arguments
            args = self._parse_syscall_args(syscall, tokens[6:])
            
            # Add errno name
            args["errno_name"] = self.ERRNO_NAMES.get(errno_val, f"E{errno_val}")
            
            # Use a sequence number for ordering since we don't have per-syscall timestamps
            # The actual timestamp comes from process events
            event = SyscallEvent(
                timestamp_us=len(self.events),  # Sequence number for ordering
                pid=pid,
                tid=tid,
                syscall=syscall,
                return_value=retval,
                errno=errno_val,
                args=args
            )
            self.events.append(event)
            
        except (ValueError, IndexError) as e:
            if self.verbose:
                print(f"Warning: Failed to parse syscall: {full_line} ({e})", file=sys.stderr)
    
    def _parse_syscall_args(self, syscall: str, args: List[str]) -> Dict[str, Any]:
        """Parse syscall-specific arguments"""
        result = {}
        
        # Clean quoted strings
        def clean_arg(a):
            if a.startswith('"') and a.endswith('"'):
                return a[1:-1]
            return a
        
        try:
            if syscall in ("open", "open_nocancel"):
                if len(args) >= 1:
                    result["path"] = clean_arg(args[0])
                if len(args) >= 2:
                    flags = int(args[1], 16) if args[1].startswith("0x") else int(args[1])
                    result["flags"] = self._parse_open_flags(flags)
                    result["flags_raw"] = flags
                if len(args) >= 3:
                    result["mode"] = args[2]
                    
            elif syscall == "openat":
                if len(args) >= 1:
                    result["dirfd"] = int(args[0])
                if len(args) >= 2:
                    result["path"] = clean_arg(args[1])
                if len(args) >= 3:
                    flags = int(args[2], 16) if args[2].startswith("0x") else int(args[2])
                    result["flags"] = self._parse_open_flags(flags)
                if len(args) >= 4:
                    result["mode"] = args[3]
                    
            elif syscall in ("read", "read_nocancel", "write", "write_nocancel"):
                if len(args) >= 1:
                    result["fd"] = int(args[0])
                if len(args) >= 2:
                    result["count"] = int(args[1])
                    
            elif syscall in ("pread", "pread_nocancel", "pwrite", "pwrite_nocancel"):
                if len(args) >= 1:
                    result["fd"] = int(args[0])
                if len(args) >= 2:
                    result["count"] = int(args[1])
                if len(args) >= 3:
                    result["offset"] = int(args[2])
                    
            elif syscall in ("close", "close_nocancel"):
                if len(args) >= 1:
                    result["fd"] = int(args[0])
                    
            elif syscall in ("stat64", "lstat64"):
                if len(args) >= 1:
                    result["path"] = clean_arg(args[0])
                    
            elif syscall == "fstat64":
                if len(args) >= 1:
                    result["fd"] = int(args[0])
                    
            elif syscall == "fstatat64":
                if len(args) >= 1:
                    result["dirfd"] = int(args[0])
                if len(args) >= 2:
                    result["path"] = clean_arg(args[1])
                if len(args) >= 3:
                    result["flag"] = args[2]
                    
            elif syscall == "getattrlistbulk":
                if len(args) >= 1:
                    result["fd"] = int(args[0])
                    
            elif syscall == "access":
                if len(args) >= 1:
                    result["path"] = clean_arg(args[0])
                if len(args) >= 2:
                    result["mode"] = int(args[1])
                    
            elif syscall in ("unlink", "rmdir", "chdir", "readlink"):
                if len(args) >= 1:
                    result["path"] = clean_arg(args[0])
                    
            elif syscall in ("rename", "link", "symlink"):
                if len(args) >= 1:
                    result["oldpath"] = clean_arg(args[0])
                if len(args) >= 2:
                    result["newpath"] = clean_arg(args[1])
                    
            elif syscall == "mkdir":
                if len(args) >= 1:
                    result["path"] = clean_arg(args[0])
                if len(args) >= 2:
                    result["mode"] = args[1]
                    
            elif syscall == "chmod":
                if len(args) >= 1:
                    result["path"] = clean_arg(args[0])
                if len(args) >= 2:
                    result["mode"] = args[1]
                    
            elif syscall == "chown":
                if len(args) >= 1:
                    result["path"] = clean_arg(args[0])
                if len(args) >= 2:
                    result["uid"] = int(args[1])
                if len(args) >= 3:
                    result["gid"] = int(args[2])
                    
            elif syscall == "socket":
                if len(args) >= 1:
                    domain = int(args[0])
                    result["domain"] = self.AF_NAMES.get(domain, f"AF_{domain}")
                if len(args) >= 2:
                    stype = int(args[1])
                    result["type"] = self.SOCK_NAMES.get(stype, f"SOCK_{stype}")
                if len(args) >= 3:
                    result["protocol"] = int(args[2])
                    
            elif syscall in ("connect", "connect_nocancel", "bind"):
                if len(args) >= 1:
                    result["fd"] = int(args[0])
                if len(args) >= 2:
                    result["addrlen"] = int(args[1])
                    
            elif syscall == "listen":
                if len(args) >= 1:
                    result["fd"] = int(args[0])
                if len(args) >= 2:
                    result["backlog"] = int(args[1])
                    
            elif syscall in ("sendto", "sendto_nocancel", "recvfrom", "recvfrom_nocancel"):
                if len(args) >= 1:
                    result["fd"] = int(args[0])
                if len(args) >= 2:
                    result["len"] = int(args[1])
                if len(args) >= 3:
                    result["flags"] = args[2]
                    
            elif syscall in ("execve", "posix_spawn"):
                if len(args) >= 1:
                    result["path"] = clean_arg(args[0])
                    
            elif syscall == "kill":
                if len(args) >= 1:
                    result["pid"] = int(args[0])
                if len(args) >= 2:
                    result["signal"] = int(args[1])
                    
            elif syscall in ("wait4", "wait4_nocancel"):
                if len(args) >= 1:
                    result["pid"] = int(args[0])
                if len(args) >= 2:
                    result["options"] = args[1]
                    
            elif syscall == "mmap":
                # mmap has complex args
                if len(args) >= 1:
                    result["length"] = int(args[0], 16) if args[0].startswith("0x") else int(args[0])
                if len(args) >= 2:
                    result["prot"] = int(args[1])
                if len(args) >= 3:
                    result["flags"] = args[2]
                if len(args) >= 4:
                    result["fd"] = int(args[3], 16) if args[3].startswith("0x") else int(args[3])
                    
            elif syscall in ("dup", "dup2"):
                if len(args) >= 1:
                    result["oldfd"] = int(args[0])
                if len(args) >= 2 and syscall == "dup2":
                    result["newfd"] = int(args[1])
                    
            elif syscall in ("fcntl", "fcntl_nocancel"):
                if len(args) >= 1:
                    result["fd"] = int(args[0])
                if len(args) >= 2:
                    result["cmd"] = int(args[1])
                if len(args) >= 3:
                    result["arg"] = int(args[2])
                    
            elif syscall == "ioctl":
                if len(args) >= 1:
                    result["fd"] = int(args[0])
                if len(args) >= 2:
                    result["request"] = args[1]
                    
            elif syscall in ("getxattr", "setxattr", "removexattr"):
                if len(args) >= 1:
                    result["path"] = clean_arg(args[0])
                if len(args) >= 2:
                    result["name"] = clean_arg(args[1])
                    
            elif syscall == "listxattr":
                if len(args) >= 1:
                    result["path"] = clean_arg(args[0])
                    
        except (ValueError, IndexError):
            # If parsing fails, store raw args
            result["raw_args"] = args
            
        return result
    
    def trace(self, command: List[str], timeout: Optional[int] = None) -> TraceResult:
        """
        Execute and trace a command.
        
        Args:
            command: Command and arguments to execute
            timeout: Optional timeout in seconds
            
        Returns:
            TraceResult with all collected data
        """
        start_time = datetime.now()
        base_timestamp = int(time.time() * 1000000)
        
        # Use dtrace -c to launch the command - this ensures tracing starts
        # before the first instruction executes (no race condition)
        
        # Prepare DTrace script - use $target which dtrace sets to the launched PID
        dtrace_script = DTRACE_SCRIPT.replace("$target_pid", "$target")
        
        with tempfile.NamedTemporaryFile(mode='w', suffix='.d', delete=False) as f:
            f.write(dtrace_script)
            dtrace_path = f.name
            
        # Build the command string for -c
        # Need to properly quote/escape for shell
        import shlex
        cmd_str = ' '.join(shlex.quote(c) for c in command)
        
        dtrace_proc = None
        target_pid = None
        target_stdout_lines = []
        target_stderr_lines = []
        dtrace_output = []
        
        try:
            # Start DTrace with -c to launch and trace the command
            # The target's stdout/stderr will be mixed with dtrace output,
            # but our MACTRACE_ prefix lets us separate them
            # Note: script must be run as root (sudo ./mactrace), so no sudo here
            dtrace_cmd = [
                "/usr/sbin/dtrace",
                "-C",  # Enable C preprocessor for #define macros
                "-s", dtrace_path,
                "-c", cmd_str
            ]
            
            if self.verbose:
                print(f"Starting DTrace: {' '.join(dtrace_cmd)}", file=sys.stderr)
            
            dtrace_proc = subprocess.Popen(
                dtrace_cmd,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE
            )
            
            # Wait for dtrace to complete (it runs until the target exits)
            try:
                stdout_data, stderr_data = dtrace_proc.communicate(timeout=timeout)
                stdout_lines = stdout_data.decode(errors='replace').splitlines()
                stderr_lines = stderr_data.decode(errors='replace').splitlines()
                
                # Separate DTrace output from target output
                # DTrace output starts with MACTRACE_ or is dtrace info
                for line in stdout_lines:
                    if line.startswith("MACTRACE_"):
                        dtrace_output.append(line)
                    elif line.startswith("dtrace:"):
                        # dtrace info/warnings go to verbose
                        if self.verbose:
                            print(f"DTrace: {line}", file=sys.stderr)
                    else:
                        # Target's stdout
                        target_stdout_lines.append(line)
                
                # stderr is usually all from the target (dtrace errors are rare)
                for line in stderr_lines:
                    if line.startswith("dtrace:"):
                        if self.verbose:
                            print(f"DTrace: {line}", file=sys.stderr)
                    else:
                        target_stderr_lines.append(line)
                        
            except subprocess.TimeoutExpired:
                dtrace_proc.kill()
                dtrace_proc.wait()
                if self.verbose:
                    print("Timeout expired, killed dtrace", file=sys.stderr)
                    
            # Extract target PID from MACTRACE_START
            for line in dtrace_output:
                if line.startswith("MACTRACE_START"):
                    parts = line.split()
                    if len(parts) >= 2:
                        target_pid = int(parts[1])
                        break
                    
        finally:
            # Cleanup
            if dtrace_proc and dtrace_proc.poll() is None:
                dtrace_proc.kill()
            try:
                os.unlink(dtrace_path)
            except:
                pass
                
        end_time = datetime.now()
        
        # Store target output for inclusion in result
        self.target_stdout = target_stdout_lines
        self.target_stderr = target_stderr_lines
        
        # Parse DTrace output
        for line in dtrace_output:
            self._parse_line(line, base_timestamp)
            
        # Build summary
        syscall_counts = {}
        for event in self.events:
            syscall_counts[event.syscall] = syscall_counts.get(event.syscall, 0) + 1
            
        # Try to get exit code from process_events
        exit_code = 0
        for pe in reversed(self.process_events):
            if pe.event_type == "exit" and pe.pid == target_pid:
                exit_code = pe.details.get("exit_code", 0)
                break
        
        return TraceResult(
            command=command,
            start_time=start_time.isoformat(),
            end_time=end_time.isoformat(),
            duration_ms=(end_time - start_time).total_seconds() * 1000,
            target_pid=target_pid or 0,
            exit_code=exit_code,
            pids_traced=list(self.pids_traced),
            process_tree=self.process_tree.copy(),
            syscall_count=len(self.events),
            events=[e.to_dict() for e in self.events],
            process_events=[e.to_dict() for e in self.process_events],
            summary=syscall_counts,
            target_stdout=self.target_stdout,
            target_stderr=self.target_stderr
        )


def main():
    parser = argparse.ArgumentParser(
        description="mactrace - strace-like utility for macOS using DTrace",
        epilog="Requires root/sudo/EUID=0 for DTrace. E.g.: sudo ./mactrace ls -la"
    )
    parser.add_argument("-o", "--output", help="Output file (default: stdout)")
    parser.add_argument("-t", "--timeout", type=int, help="Timeout in seconds")
    parser.add_argument("-v", "--verbose", action="store_true", help="Verbose output to stderr")
    parser.add_argument("-p", "--pretty", action="store_true", help="Pretty-print JSON output")
    parser.add_argument("-e", "--untraced", action="store_true", 
                        help="Show untraced syscalls summary to stderr")
    parser.add_argument("command", nargs=argparse.REMAINDER, help="Command to trace")
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        sys.exit(1)
        
    # Check if running as root
    if os.geteuid() != 0:
        print("Error: mactrace requires root privileges. Run with sudo.", file=sys.stderr)
        sys.exit(1)
        
    tracer = MacTrace(verbose=args.verbose)
    result = tracer.trace(args.command, timeout=args.timeout)
    
    # Print target's output to stderr so it doesn't mix with JSON
    if result.target_stdout:
        print("--- Target stdout ---", file=sys.stderr)
        for line in result.target_stdout:
            print(line, file=sys.stderr)
    if result.target_stderr:
        print("--- Target stderr ---", file=sys.stderr)
        for line in result.target_stderr:
            print(line, file=sys.stderr)
    
    # Summary to stderr
    print(f"--- Trace summary ---", file=sys.stderr)
    print(f"PID: {result.target_pid}, Exit code: {result.exit_code}", file=sys.stderr)
    print(f"Syscalls: {result.syscall_count}, Processes: {len(result.pids_traced)}", file=sys.stderr)
    print(f"Duration: {result.duration_ms:.1f}ms", file=sys.stderr)
    
    # Show untraced syscalls if requested
    if args.untraced and tracer.all_syscall_counts:
        untraced = {}
        for syscall, count in tracer.all_syscall_counts.items():
            # Check if this syscall (or its _nocancel variant) is explicitly traced
            base_name = syscall.replace("_nocancel", "")
            if syscall not in tracer.TRACED_SYSCALLS and base_name not in tracer.TRACED_SYSCALLS:
                untraced[syscall] = count
        
        if untraced:
            print(f"--- Untraced syscalls ---", file=sys.stderr)
            for syscall, count in sorted(untraced.items(), key=lambda x: -x[1]):
                print(f"  {syscall}: {count}", file=sys.stderr)
        else:
            print(f"--- All syscalls traced ---", file=sys.stderr)
    
    # Output JSON
    output_data = json.dumps(result.to_dict(), indent=2 if args.pretty else None)
    
    if args.output:
        with open(args.output, 'w') as f:
            f.write(output_data)
        print(f"Trace written to: {args.output}", file=sys.stderr)
    else:
        print(output_data)


if __name__ == "__main__":
    main()
