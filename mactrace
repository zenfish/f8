from mactrace_categories import get_category as get_syscall_category


@dataclass
class SyscallEvent:
    """A single syscall event"""
    timestamp_us: int
    pid: int
    tid: int
    syscall: str
    return_value: int
    errno: int
    args: Dict[str, Any] = field(default_factory=dict)
    category: str = ""
    
    def __post_init__(self):
        if not self.category:
            self.category = get_syscall_category(self.syscall)
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            "timestamp_us": self.timestamp_us,
            "pid": self.pid,
            "tid": self.tid,
            "syscall": self.syscall,
            "category": self.category,
            "return_value": self.return_value,
            "errno": self.errno,
            "args": self.args
        }


@dataclass 
class ProcessEvent:
    """Process lifecycle event (fork, exec, exit)"""
    timestamp_us: int
    event_type: str  # fork, exec, exit
    pid: int
    tid: int
    details: Dict[str, Any] = field(default_factory=dict)
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            "timestamp_us": self.timestamp_us,
            "event_type": self.event_type,
            "pid": self.pid,
            "tid": self.tid,
            **self.details
        }


@dataclass
class TraceResult:
    """Complete trace result"""
    command: List[str]
    start_time: str
    end_time: str
    duration_ms: float
    target_pid: int
    exit_code: int
    pids_traced: List[int]
    process_tree: Dict[int, int]  # child_pid -> parent_pid
    syscall_count: int
    events: List[Dict[str, Any]]
    process_events: List[Dict[str, Any]]
    summary: Dict[str, int]
    target_stdout: List[str]
    target_stderr: List[str]
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            "command": self.command,
            "start_time": self.start_time,
            "end_time": self.end_time,
            "duration_ms": self.duration_ms,
            "target_pid": self.target_pid,
