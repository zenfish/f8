        "chmod", "fchmod", "truncate", "ftruncate",
        "link", "symlink", "readlink",
        "dup", "dup2", "fcntl", "fcntl_nocancel", "ioctl", "fsync", "fsync_nocancel",
        "getdirentries64", "getattrlistbulk",
