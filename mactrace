    # ── --iovec-syscalls help ─────────────────────────────────────────
    if getattr(args, 'iovec_syscalls', None) == 'help':
        print("""Vectored I/O syscalls (--iovec-syscalls):

  Syscall     Variants                Description
  ─────────── ─────────────────────── ──────────────────────────────────
  readv       readv, readv_nocancel   Read into multiple buffers (scatter)
  writev      writev, writev_nocancel Write from multiple buffers (gather)
  preadv      preadv                  Positional scatter read
  pwritev     pwritev                 Positional gather write

Usage:
  --iovec 4 --iovec-syscalls=writev       Cheapest: 2 variants, ~34 DIF programs
  --iovec 4 --iovec-syscalls=readv,writev Balanced: 4 variants, ~68 DIF programs
  --iovec 4                               All 6 variants, ~102 DIF programs

Each iovec slot costs ~4 DIF programs per syscall variant.
The _nocancel variants are included automatically.""")
        sys.exit(0)
    
    # ── --trace help [category] ───────────────────────────────────────
    if args.trace and args.trace.split()[0].lower() == 'help':
        from syscalls import get_category_info, CATEGORY_ALIASES, CATEGORY_DESCRIPTIONS
        cat_info = get_category_info()
        
        # Parse target: --trace "help network" or --trace help <command captures "network">
        help_parts = args.trace.split(maxsplit=1)
        target = help_parts[1].lower() if len(help_parts) > 1 else None
        if not target and args.command:
            target = args.command[0].lower()
        
        if target:
            # Resolve alias → categories
            if target in CATEGORY_ALIASES and CATEGORY_ALIASES[target] is not None:
                cats = CATEGORY_ALIASES[target]
                print(f"Alias '{target}' → {', '.join(cats)}")
                print()
                for cat in cats:
                    if cat in cat_info:
                        _print_category_detail(cat, cat_info[cat])
            elif target in cat_info:
                _print_category_detail(target, cat_info[target])
            else:
                print(f"Unknown category or alias: '{target}'")
                print(f"Categories: {', '.join(sorted(cat_info.keys()))}")
                print(f"Aliases: {', '.join(k for k, v in sorted(CATEGORY_ALIASES.items()) if v is not None)}")
        else:
            # List all categories
            total_syscalls = set()
            for info in cat_info.values():
                total_syscalls.update(info['syscalls'])
            
            print(f"Trace categories ({len(cat_info)} categories, {len(total_syscalls)} traced syscalls):")
            print()
            for cat, info in sorted(cat_info.items()):
                print(f"  {cat:12s}  {len(info['syscalls']):3d} syscalls  {info['description']}")
            
            print()
            print("Aliases:")
            for alias, cats in sorted(CATEGORY_ALIASES.items()):
                if cats is not None:
                    print(f"  {alias:12s}  → {', '.join(cats)}")
                else:
                    print(f"  {alias:12s}  → all categories")
            
            print()
            print("Usage: --trace help <category>  for syscall details")
            print("       --trace help <alias>     to expand an alias")
        
        sys.exit(0)
    
    if not args.command and args.pid is None:
        parser.print_help()
        sys.exit(1)
    
    if args.command and args.pid is not None:
        print("Error: Cannot use both -p PID and a command. Choose one.", file=sys.stderr)
        sys.exit(1)
        
    # Check if running as root
    if os.geteuid() != 0:
        print("Error: mactrace requires root privileges. Run with sudo.", file=sys.stderr)
        sys.exit(1)
    
    # Auto-derive output name from command when no -o given
    # "./configure" → "configure", "/usr/bin/ls" → "ls", "sh -c ..." → "sh"
    if not args.output and args.command and not args.pid:
        import os.path as _osp
        _cmd_name = _osp.basename(args.command[0])
        # Strip common extensions (.sh, .py, .pl, .rb)
        _cmd_base, _ext = _osp.splitext(_cmd_name)
        if _ext in ('.sh', '.py', '.pl', '.rb', '.bash', '.zsh'):
            _cmd_name = _cmd_base
        args.output = _cmd_name

    # Inject epoch timestamp into output filename for uniqueness
    # "make" → "make.1740000000.json" (auto epoch + .json)
    # "make.json" → "make.json" (explicit .json = exact name, no epoch)
    if args.output:
        if not args.output.endswith('.json'):
            import time as _time
            _epoch = int(_time.time())
            _out = args.output
            # Only add timestamp if not already present (10-digit number at end)
            if not re.search(r'\.\d{10}$', _out):
                _out = f"{_out}.{_epoch}"
            args.output = f"{_out}.json"
    
    # Check output file doesn't exist (fail fast, before tracing)
    if args.output:
        output_path = resolve_path(args.output, 'MACTRACE_OUTPUT', check_exists=False)
        if os.path.exists(output_path):
            print(f"Error: Output file already exists:\n\n    {output_path}\n", file=sys.stderr)
            print(f"Will not overwrite. Remove the file or choose a different output path.", file=sys.stderr)
            sys.exit(1)
    
    # Resolve user: -u/--user flag > MACTRACE_USER env var > SUDO_USER (auto-detect)
    user_spec = args.user or os.environ.get('MACTRACE_USER')
    run_as_user = None
    
    if user_spec:
        try:
            run_as_user = resolve_user(user_spec)
            if args.verbose:
                print(f"Will run traced program as user: {run_as_user[2]} (uid={run_as_user[0]}, gid={run_as_user[1]})", file=sys.stderr)
        except ValueError as e:
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)
    else:
        # Auto-detect: if running under sudo, use the original user
        sudo_user = os.environ.get('SUDO_USER')
        if sudo_user:
            try:
                run_as_user = resolve_user(sudo_user)
                if args.verbose:
                    print(f"Auto-detected sudo caller: {run_as_user[2]} (uid={run_as_user[0]}, gid={run_as_user[1]})", file=sys.stderr)
            except ValueError as e:
                # SUDO_USER exists but user doesn't - weird, but continue as root
                if args.verbose:
                    print(f"Warning: SUDO_USER={sudo_user} but user not found, running as root", file=sys.stderr)
    
    # Parse cache option
    cache_size = 0
    cache_dir = None
    if args.cache:
        try:
            cache_size = parse_size(args.cache)
            # Create cache directory next to output file or in temp
            if args.output:
                output_path = resolve_path(args.output, 'MACTRACE_OUTPUT', check_exists=False)
                cache_dir = output_path.rsplit('.', 1)[0] + '_cache'
            else:
                cache_dir = tempfile.mkdtemp(prefix='mactrace_cache_')
            dir_existed = os.path.exists(cache_dir)
            os.makedirs(cache_dir, exist_ok=True)
            # Chown cache dir to the user we'll run as
            if not dir_existed and run_as_user:
                try:
                    os.chown(cache_dir, run_as_user[0], run_as_user[1])
                except OSError:
                    pass
            if args.verbose:
                print(f"File cache enabled: up to {args.cache} per file → {cache_dir}/", file=sys.stderr)
        except ValueError as e:
            print(f"Error: Invalid --cache size '{args.cache}': {e}", file=sys.stderr)
            sys.exit(1)
        

    # ── iovec arg processing ──────────────────────────────────────
    iovec_max = args.iovec
    iovec_syscalls = None
    if args.iovec_syscalls:
        valid_iovec = {'readv', 'writev', 'preadv', 'pwritev'}
        iovec_syscalls = set(s.strip() for s in args.iovec_syscalls.split(','))
        bad = iovec_syscalls - valid_iovec
        if bad:
            parser.error(f"Invalid --iovec-syscalls: {', '.join(sorted(bad))}. "
                         f"Valid: {', '.join(sorted(valid_iovec))}")
        if iovec_max is None:
            parser.error('--iovec-syscalls requires --iovec N')
    if iovec_max is not None and iovec_max < 1:
        parser.error('--iovec N must be >= 1')
    if iovec_max is not None and iovec_max > 64:
        parser.error(f'--iovec {iovec_max} is extreme. Max supported: 64.')
    tracer = MacTrace(
        verbose=args.verbose,
        capture_io=args.capture_io,
        iovec_max=iovec_max, iovec_syscalls=iovec_syscalls,
        io_size=args.io_size,
        strsize=args.strsize,
        bufsize=args.bufsize,
        dynvarsize=args.dynvarsize,
        switchrate=args.switchrate,
        cleanrate=args.cleanrate,
        cache_size=cache_size,
        cache_dir=cache_dir,
        trace_spec=args.trace
    )
    
    # ── Dynamic DTrace kernel limit sizing ─────────────────────────────────────
    # Two kernel limits gate DTrace compilation:
    #   kern.dtrace.difo_maxsize — max size of a single DIF object (per-probe bytecode)
    #   kern.dtrace.dof_maxsize  — max size of the entire DOF (compiled program)
    #
    # macOS defaults: difo=256KB, dof=512KB. With 200+ probes + IO capture,
    # we routinely exceed dof_maxsize. DTrace's error message is misleading:
    # "DIF program exceeds maximum program size" fires for BOTH limits.
    import subprocess as _sp

    def _read_sysctl(name, default):
        try:
            r = _sp.run(['/usr/sbin/sysctl', '-n', name], capture_output=True, text=True)
            return int(r.stdout.strip())
        except (ValueError, OSError):
            return default

    current_difo = _read_sysctl('kern.dtrace.difo_maxsize', 262144)
    current_dof  = _read_sysctl('kern.dtrace.dof_maxsize',  524288)

    original_difo_maxsize = None
    original_dof_maxsize  = None

    # Count ALL DIF programs: base probes + I/O capture + iovec
    # These are appended during trace_command/trace_pid, but we need
    # the count NOW for auto-sizing.
    dif_count = count_dif_programs(tracer._dtrace_script)
    if tracer.capture_io:
        io_probes = tracer._build_io_capture_probes(tracer.io_size)
        dif_count += count_dif_programs(io_probes)
        if tracer.iovec_max is not None:
            iov_probes = tracer._build_iovec_capture_probes(
                tracer.io_size, tracer.iovec_max, tracer.iovec_syscalls)
            dif_count += count_dif_programs(iov_probes)

    # ── difo_maxsize (per-probe limit) ──────────────────────────────────
    # Budget formula: 250 probes fit in 256KB (262144 bytes)
    PROBES_PER_256K = 250
    BASE_DIFO = 262144

    # Calculate needed difo_maxsize for our probe count (with 20% headroom)
    needed_difo = int((dif_count / PROBES_PER_256K) * BASE_DIFO * 1.2)
    # Round up to nearest 64KB
    needed_difo = ((needed_difo + 65535) // 65536) * 65536
    # Floor at kernel default
    needed_difo = max(needed_difo, BASE_DIFO)

    if args.dynamic_max is not None:
        # Explicit -d override: use that value
        target_difo = args.dynamic_max
    else:
        # Auto-adjust: raise if needed, leave alone if sufficient
        target_difo = needed_difo if needed_difo > current_difo else current_difo

    # ── dof_maxsize (total DOF limit) ───────────────────────────────────
    # The compiled DOF (all probes + actions + strings + metadata) needs
    # room to fit. Empirically, each probe clause compiles to ~2-4KB of DOF,
    # plus IO capture probes with tracemem() are heavier (~8-16KB each).
    # Use 8KB/probe as a conservative estimate with 50% headroom.
    DOF_BYTES_PER_PROBE = 8192
    needed_dof = int(dif_count * DOF_BYTES_PER_PROBE * 1.5)
    # Round up to nearest 256KB
    needed_dof = ((needed_dof + 262143) // 262144) * 262144
    # Floor at kernel default
    needed_dof = max(needed_dof, 524288)
    target_dof = needed_dof if needed_dof > current_dof else current_dof

    # ── Apply difo_maxsize ──────────────────────────────────────────
    if target_difo != current_difo:
        original_difo_maxsize = current_difo
        try:
            _sp.run(['/usr/sbin/sysctl', f'kern.dtrace.difo_maxsize={target_difo}'],
                    capture_output=True, check=True)
        except _sp.CalledProcessError as e:
            print(f"Warning: Could not set kern.dtrace.difo_maxsize={target_difo}: {e.stderr.strip()}", file=sys.stderr)
            target_difo = current_difo
            original_difo_maxsize = None
        else:
            if args.dynamic_max is not None:
                print(f"kern.dtrace.difo_maxsize: {current_difo} → {target_difo} (manual -d override)", file=sys.stderr)
            else:
                print(f"kern.dtrace.difo_maxsize: {current_difo} → {target_difo} (auto-adjusted for {dif_count} probes)", file=sys.stderr)

    # ── Apply dof_maxsize ───────────────────────────────────────────
    if target_dof != current_dof:
        original_dof_maxsize = current_dof
        try:
            _sp.run(['/usr/sbin/sysctl', f'kern.dtrace.dof_maxsize={target_dof}'],
                    capture_output=True, check=True)
        except _sp.CalledProcessError as e:
            print(f"Warning: Could not set kern.dtrace.dof_maxsize={target_dof}: {e.stderr.strip()}", file=sys.stderr)
            target_dof = current_dof
            original_dof_maxsize = None
        else:
            print(f"kern.dtrace.dof_maxsize: {current_dof} → {target_dof} (auto-adjusted for {dif_count} probes)", file=sys.stderr)

    # ── Restore on ANY exit: atexit + signal handlers ───────────────────
    if original_difo_maxsize is not None or original_dof_maxsize is not None:
        import atexit
        _dtrace_limits_restored = False
        def _restore_dtrace_limits():
            nonlocal _dtrace_limits_restored
            if _dtrace_limits_restored:
                return
            _dtrace_limits_restored = True
            try:
                if original_difo_maxsize is not None:
                    _sp.run(['/usr/sbin/sysctl', f'kern.dtrace.difo_maxsize={original_difo_maxsize}'],
                            capture_output=True)
                if original_dof_maxsize is not None:
                    _sp.run(['/usr/sbin/sysctl', f'kern.dtrace.dof_maxsize={original_dof_maxsize}'],
                            capture_output=True)
            except Exception:
                pass
        atexit.register(_restore_dtrace_limits)

        import signal as _sig
        def _signal_restore(signum, frame):
            _restore_dtrace_limits()
            _sig.signal(signum, _sig.SIG_DFL)
            os.kill(os.getpid(), signum)
        _sig.signal(_sig.SIGTERM, _signal_restore)
        _sig.signal(_sig.SIGHUP, _signal_restore)
    
    # Budget reporting (based on effective difo_maxsize)
    _effective_max = target_difo
    dif_budget = int(PROBES_PER_256K * _effective_max / BASE_DIFO)
    dif_pct = min(100, int(dif_count / dif_budget * 100))
    is_filtered = args.trace and args.trace.lower() != 'all'
    if is_filtered:
        # Build a descriptive label for what's loaded
        spec_parts = []
        if tracer._trace_cats:
            spec_parts.extend(sorted(tracer._trace_cats))
        if tracer._trace_syscalls:
            spec_parts.extend(sorted(tracer._trace_syscalls))
        label = ', '.join(spec_parts) if spec_parts else args.trace
        print(f"DTrace probes: {dif_count} loaded ({label}), ~{dif_pct}% of DIF budget", file=sys.stderr)
    elif args.verbose:
        print(f"DTrace probes: {dif_count} loaded (all), ~{dif_pct}% of DIF budget", file=sys.stderr)
    if args.capture_io:
        # IO capture adds ~30% more probes
        io_extra = int(dif_count * 0.15)  # rough estimate for IO capture probes
        combined_pct = min(100, int((dif_count + io_extra) / dif_budget * 100))
        if combined_pct > 90:
            print(f"  ⚠️  With -c (I/O capture), estimated ~{combined_pct}% of DIF budget", file=sys.stderr)
    if args.iovec is not None:
        # Report iovec DIF cost
        n_variants = len(tracer.iovec_syscalls or {'readv', 'writev', 'preadv', 'pwritev'})
        # Account for _nocancel variants (readv and writev have them)
        n_actual = 0
        for s in (tracer.iovec_syscalls or {'readv', 'writev', 'preadv', 'pwritev'}):
            n_actual += 2 if s in ('readv', 'writev') else 1
        iovec_cost = n_actual * args.iovec * 4 + n_actual  # +n_actual for cleanup clauses
        iovec_pct = int(iovec_cost / dif_budget * 100)
        if dif_pct > 95:
            print(f"  ❌  --iovec {args.iovec} adds ~{iovec_cost} DIF programs ({iovec_pct}% of budget) — over budget!", file=sys.stderr)
            print(f"       Fix: narrow with --trace=file, --iovec-syscalls=writev, or lower N", file=sys.stderr)
        elif dif_pct > 80:
            print(f"  ⚠️  --iovec {args.iovec} adds ~{iovec_cost} DIF programs ({iovec_pct}% of budget) — tight", file=sys.stderr)
        elif args.verbose:
            print(f"  --iovec {args.iovec}: ~{iovec_cost} DIF programs ({iovec_pct}% of budget)", file=sys.stderr)

    if args.pid is not None:
        # Attach to already-running process (like strace -p)
        result = tracer.trace_pid(args.pid, timeout=args.timeout)
    else:
        # Workaround for macOS 15+ dtrace bug: scripts with #!/bin/sh shebang
        # fail to execute properly when launched via dtrace -c. The script
        # exits immediately after sh execs to bash. Fix by explicitly running
        # such scripts via /bin/bash.
        command = args.command
        if command and os.path.isfile(command[0]):
            try:
                with open(command[0], 'rb') as f:
                    shebang = f.read(64)
                    # Check for #!/bin/sh (but not #!/bin/bash)
                    if shebang.startswith(b'#!') and b'/bin/sh' in shebang.split(b'\n')[0] and b'bash' not in shebang:
                        if args.verbose:
                            print(f"Detected #!/bin/sh script, wrapping with /bin/bash to work around macOS dtrace bug", file=sys.stderr)
                        command = ['/bin/bash'] + command
            except (IOError, OSError):
                pass  # Not readable, let it fail naturally
        
        result = tracer.trace(command, timeout=args.timeout, run_as_user=run_as_user,
                              throttle=args.throttle)
        
        # Filter out wrapper processes (sudo, sh, bash, taskpolicy) when using
        # -u or --throttle. Keeps only the real target command and its children.
        if (run_as_user or args.throttle) and not args.no_filter_wrapper:
            result = filter_wrapper_processes(result, command, verbose=args.verbose)
    
    # Target stdout/stderr is already echoed to TTY in real-time during tracing
    # No need to print again here
    
    # Summary to stderr
    # Calculate capture stats from DTrace diagnostics
    import re as _re
    _total_drops = sum(int(m.group(1)) for line in tracer._dtrace_errors
                       if (m := _re.search(r'(\d+) drops on CPU', line)))
    _capture_pct = ""
    if _total_drops > 0:
        pct = result.syscall_count / (result.syscall_count + _total_drops) * 100
        _capture_pct = f" ({pct:.0f}% captured, {_total_drops:,} dropped)"
    
    print(f"--- Trace summary ---", file=sys.stderr)
    print(f"PID: {result.target_pid}, Exit code: {result.exit_code}", file=sys.stderr)
    print(f"Syscalls: {result.syscall_count:,}{_capture_pct}, Processes: {len(result.pids_traced)}", file=sys.stderr)
    print(f"Duration: {result.duration_ms:.1f}ms", file=sys.stderr)
    
    # Show untraced syscalls if requested
    if args.untraced and tracer.all_syscall_counts:
        untraced = {}
        for syscall, count in tracer.all_syscall_counts.items():
            # Check if this syscall (or its _nocancel variant) is explicitly traced
            base_name = syscall.replace("_nocancel", "")
            if syscall not in tracer._traced_syscalls and base_name not in tracer._traced_syscalls:
                untraced[syscall] = count
        
        if untraced:
            print(f"--- Untraced syscalls ---", file=sys.stderr)
            for syscall, count in sorted(untraced.items(), key=lambda x: -x[1]):
                print(f"  {syscall}: {count}", file=sys.stderr)
        else:
            print(f"--- All syscalls traced ---", file=sys.stderr)
    
    # DTrace health summary (drops, scratch errors, I/O truncation, rerun suggestions)
    tracer.summarize_dtrace_health(result.syscall_count, used_throttle=args.throttle)
    
    # Wait for cache operations to complete
    if cache_dir and tracer._cached_files:
        success_count, error_count = tracer.wait_for_cache()
        if success_count > 0:
            print(f"Cached {success_count} file(s) to: {cache_dir}/", file=sys.stderr)
        if error_count > 0:
            print(f"Failed to cache {error_count} file(s)", file=sys.stderr)
    
    # If trace was interrupted, clean up and exit
    if result.interrupted:
        print(f"\nTrace interrupted — cleaning up.", file=sys.stderr)
        # Remove output JSON if it exists (shouldn't yet, but be safe)
        if args.output:
            output_path = resolve_path(args.output, 'MACTRACE_OUTPUT', check_exists=False)
            if os.path.exists(output_path):
                os.unlink(output_path)
                print(f"  Removed: {output_path}", file=sys.stderr)
        # Remove cache directory if we created it
        if cache_dir and os.path.isdir(cache_dir):
            import shutil
            shutil.rmtree(cache_dir, ignore_errors=True)
            print(f"  Removed: {cache_dir}/", file=sys.stderr)
        sys.exit(130)  # 128 + SIGINT — conventional interrupted exit code

    # Output JSON
    output_data = json.dumps(result.to_dict(), indent=2 if args.json_pretty else None)
    
    if args.output:
        # output_path was already resolved and validated at startup
        output_path = resolve_path(args.output, 'MACTRACE_OUTPUT', check_exists=False)
        
        # Ensure output directory exists
        output_dir = os.path.dirname(output_path)
        if output_dir:
            dir_created = not os.path.exists(output_dir)
            os.makedirs(output_dir, exist_ok=True)
            # Chown newly created directory to the user we ran as
            if dir_created and run_as_user:
                try:
                    os.chown(output_dir, run_as_user[0], run_as_user[1])
                except OSError:
                    pass  # Best effort
        
        with open(output_path, 'w') as f:
            f.write(output_data)
        
        # Chown output file to the user we ran as (not root)
        if run_as_user:
            try:
                os.chown(output_path, run_as_user[0], run_as_user[1])
            except OSError as e:
                if args.verbose:
                    print(f"Warning: Could not chown {output_path}: {e}", file=sys.stderr)
        
        print(f"Trace written to: {output_path}", file=sys.stderr)
    else:
        print(output_data)


if __name__ == "__main__":
    main()
