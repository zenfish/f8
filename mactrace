/TRACED && arg1 > 0/
{{
    printf("MACTRACE_IO %d %d sendmsg %d %d\\n", pid, tid, self->sendmsg_fd, (int)arg1);
}}

syscall::recvmsg:return,
syscall::recvmsg_nocancel:return
/TRACED && arg1 > 0/
{{
    printf("MACTRACE_IO %d %d recvmsg %d %d\\n", pid, tid, self->recvmsg_fd, (int)arg1);
}}
'''
            dtrace_script += io_capture_probes
        else:
            dtrace_script = dtrace_script.replace("$RAWIO_PRAGMA$", "")
        
        with tempfile.NamedTemporaryFile(mode='w', suffix='.d', delete=False) as f:
            f.write(dtrace_script)
            dtrace_path = f.name
        
        # Create temp file for dtrace output
        dtrace_output_file = tempfile.NamedTemporaryFile(mode='w', suffix='.dtrace', delete=False)
        dtrace_output_path = dtrace_output_file.name
        dtrace_output_file.close()
        
        dtrace_output = []
        dtrace_proc = None
        
        try:
            # Start DTrace with -p to attach to the running process
            dtrace_cmd = [
                "/usr/sbin/dtrace",
                "-C",  # Enable C preprocessor for #define macros
                "-o", dtrace_output_path,  # Write dtrace output to file
                "-s", dtrace_path,
                "-p", str(target_pid)
            ]
            
            if self.verbose:
                print(f"Attaching DTrace to PID {target_pid} ({proc_name}): {' '.join(dtrace_cmd)}", file=sys.stderr)
            
            print(f"Tracing PID {target_pid} ({proc_name})... Ctrl+C to stop.", file=sys.stderr)
            
            dtrace_proc = subprocess.Popen(
                dtrace_cmd,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE
            )
            
            # Snapshot open fds async — runs in parallel with tracing.
            # Only need this once: any new fds opened during tracing will be
            # caught by the dtrace probes (socket/open/connect/etc.).
            # Uses -n (no DNS) and -P (no port names) to avoid slow lookups.
            lsof_thread = threading.Thread(
                target=self._snapshot_fds_from_lsof, args=(target_pid,), daemon=True)
            lsof_thread.start()
            
            # Read dtrace stderr in background to capture/display dtrace messages
            dtrace_stderr_lines = []
            
            def read_dtrace_stderr():
                for line_bytes in dtrace_proc.stderr:
                    line = line_bytes.decode(errors='replace').rstrip('\n')
                    if line.lstrip().startswith('dtrace:'):
                        if self.verbose:
                            print(f"DTrace: {line.lstrip()}", file=sys.stderr)
                    dtrace_stderr_lines.append(line)
            
            # Read dtrace stdout (shouldn't have much since -o sends to file)
            def read_dtrace_stdout():
                for line_bytes in dtrace_proc.stdout:
                    pass  # Discard - output goes to -o file
            
            stderr_thread = threading.Thread(target=read_dtrace_stderr, daemon=True)
            stdout_thread = threading.Thread(target=read_dtrace_stdout, daemon=True)
            stderr_thread.start()
            stdout_thread.start()
            
            # Wait for dtrace to complete (process exit, Ctrl+C, or timeout)
            # Handle Ctrl+C gracefully - send SIGINT to dtrace so it flushes output
            try:
                dtrace_proc.wait(timeout=timeout)
            except subprocess.TimeoutExpired:
                print(f"\nTimeout ({timeout}s) expired, stopping trace...", file=sys.stderr)
                dtrace_proc.send_signal(signal.SIGINT)
                try:
                    dtrace_proc.wait(timeout=5)
                except subprocess.TimeoutExpired:
                    dtrace_proc.kill()
                    dtrace_proc.wait()
            except KeyboardInterrupt:
                print(f"\nStopping trace...", file=sys.stderr)
                dtrace_proc.send_signal(signal.SIGINT)
                try:
                    dtrace_proc.wait(timeout=5)
                except subprocess.TimeoutExpired:
                    dtrace_proc.kill()
                    dtrace_proc.wait()
            
            stderr_thread.join(timeout=2)
            stdout_thread.join(timeout=2)
            
            # Read dtrace output from file
            try:
                with open(dtrace_output_path, 'r', errors='replace') as f:
                    for line in f:
                        line = line.rstrip('\n')
                        if line:
                            dtrace_output.append(line)
            except Exception as e:
                if self.verbose:
                    print(f"Error reading dtrace output: {e}", file=sys.stderr)
                    
        finally:
            if dtrace_proc and dtrace_proc.poll() is None:
                dtrace_proc.kill()
            try:
                os.unlink(dtrace_path)
            except:
                pass
            try:
                os.unlink(dtrace_output_path)
            except:
                pass
        
        end_time = datetime.now()
        
        # No target stdout/stderr when attaching to running process
        self.target_stdout = []
        self.target_stderr = []
        
        # Wait for lsof snapshot to finish before parsing events
        # (so fd type info is available for recategorization)
        lsof_thread.join(timeout=10)
        
        # Pre-process: merge hexdump blocks
        dtrace_output = self._merge_io_hexdumps(dtrace_output)
        
        # Parse DTrace output
        for line in dtrace_output:
            self._parse_line(line, base_timestamp)
        
        # Build summary
        syscall_counts = {}
        for event in self.events:
            syscall_counts[event.syscall] = syscall_counts.get(event.syscall, 0) + 1
        
        # Try to get exit code from process_events
        exit_code = -1  # -1 means process may still be running
        for pe in reversed(self.process_events):
            if pe.event_type == "exit" and pe.pid == target_pid:
                exit_code = pe.details.get("exit_code", 0)
                break
        
        self.pids_traced.add(target_pid)
        
        return TraceResult(
            command=[f"[attached:{proc_name}]"],
            start_time=start_time.isoformat(),
            end_time=end_time.isoformat(),
            duration_ms=(end_time - start_time).total_seconds() * 1000,
            target_pid=target_pid,
            exit_code=exit_code,
            pids_traced=list(self.pids_traced),
            process_tree=self.process_tree.copy(),
            syscall_count=len(self.events),
            events=[e.to_dict() for e in self.events],
            process_events=[e.to_dict() for e in self.process_events],
            summary=syscall_counts,
            target_stdout=self.target_stdout,
            target_stderr=self.target_stderr
        )


def get_mactrace_config() -> Dict[str, str]:
    """
    Load mactrace configuration, handling sudo environment stripping.
    
    Priority:
    1. Environment variables (if set)
    2. Config file at $MACTRACE_HOME/config or ~SUDO_USER/.mactrace/config
    3. Defaults
    
    Config file format:
        # Comments
        KEY=value
        KEY2=$KEY/subdir      # Variable expansion
        KEY3=~/path           # ~ expands to sudo user's home
    
    Returns:
        Dict with config values (MACTRACE_OUTPUT, MACTRACE_HOME, etc.)
    """
    import pwd
    import re
    
    config = {}
    
    # Determine sudo user's home for ~ expansion
    sudo_user = os.environ.get('SUDO_USER')
    if sudo_user:
        try:
            sudo_home = pwd.getpwnam(sudo_user).pw_dir
        except KeyError:
            sudo_home = os.path.expanduser('~')
    else:
        sudo_home = os.environ.get('HOME', os.path.expanduser('~'))
    
    def expand_value(value: str) -> str:
        """Expand ~ and $VAR references in a value."""
        # Expand ~ to sudo user's home
        if value.startswith('~/'):
            value = sudo_home + value[1:]
        elif value == '~':
            value = sudo_home
        
        # Expand $VAR and ${VAR} references to config values
        def replace_var(match):
            var_name = match.group(1) or match.group(2)
            # Check config first, then environment
            return config.get(var_name, os.environ.get(var_name, match.group(0)))
        
        # Match $VAR or ${VAR}
        value = re.sub(r'\$\{(\w+)\}|\$(\w+)', replace_var, value)
        return value
    
    # First, try to find MACTRACE_HOME
    mactrace_home = os.environ.get('MACTRACE_HOME')
    if not mactrace_home:
        mactrace_home = os.path.join(sudo_home, '.mactrace')
    
    config['MACTRACE_HOME'] = mactrace_home
    
    # Try to read config file
    config_file = os.path.join(mactrace_home, 'config')
    if os.path.exists(config_file):
        try:
            with open(config_file) as f:
                for line in f:
                    line = line.strip()
                    if line and not line.startswith('#') and '=' in line:
                        key, value = line.split('=', 1)
                        key = key.strip()
                        value = value.strip().strip('"').strip("'")
                        value = expand_value(value)
                        config[key] = value
        except (IOError, OSError):
            pass
    
    # Environment variables override config file
    for key in ['MACTRACE_OUTPUT', 'MACTRACE_HOME', 'MACTRACE_USER', 'MACTRACE_DB']:
        env_val = os.environ.get(key)
        if env_val:
            config[key] = env_val
    
    return config


# Global config loaded once
_mactrace_config: Optional[Dict[str, str]] = None

def get_config_value(key: str) -> Optional[str]:
    """Get a mactrace config value."""
    global _mactrace_config
    if _mactrace_config is None:
        _mactrace_config = get_mactrace_config()
    return _mactrace_config.get(key)


def resolve_path(path: str, env_var: str, check_exists: bool = True) -> str:
    """
    Resolve a path, prepending config/environment variable if path is relative.
    
    Rules:
    - Absolute paths (starting with '/') are used as-is
    - Paths starting with './' or '../' are used as-is (explicit relative)
    - Other paths have $env_var prepended (if set via env or config file)
    
    Args:
        path: The path to resolve
        env_var: Config/environment variable name to use as prefix (e.g., 'MACTRACE_OUTPUT')
        check_exists: If True, check if the resolved path exists before returning
                     (falls back to original path if not found)
    
    Returns:
        Resolved path
    """
    # Absolute path - use as-is
    if path.startswith('/'):
        return path
    
    # Explicit relative path (./ or ../) - use as-is
    if path.startswith('./') or path.startswith('../'):
        return path
    
    # Check config (includes env vars)
    env_value = get_config_value(env_var)
    if not env_value:
        return path
    
    # Build candidate path
    candidate = os.path.join(env_value, path)
    
    # If check_exists, verify the file exists at the candidate location
    if check_exists:
        if os.path.exists(candidate):
            return candidate
        # Fall back to original if candidate doesn't exist
        return path
    
    # For output paths (check_exists=False), always use the env var prefix
    return candidate


def resolve_user(user_spec: Optional[str]) -> Optional[tuple]:
    """
    Resolve a user specification to (uid, gid, username).
    
    Args:
        user_spec: Username or numeric UID, or None
        
    Returns:
        Tuple of (uid, gid, username) or None if no user specified
        
    Raises:
        ValueError: If user doesn't exist
    """
    if not user_spec:
        return None
    
    import pwd
    
    try:
        # Try as numeric UID first
        uid = int(user_spec)
        try:
            pw = pwd.getpwuid(uid)
            return (pw.pw_uid, pw.pw_gid, pw.pw_name)
        except KeyError:
            raise ValueError(f"No user with UID {uid}")
    except ValueError:
        pass
    
    # Try as username
    try:
        pw = pwd.getpwnam(user_spec)
        return (pw.pw_uid, pw.pw_gid, pw.pw_name)
    except KeyError:
        raise ValueError(f"No user named '{user_spec}'")


def get_mactrace_home() -> str:
    """Get MACTRACE_HOME, defaulting to ~/.mactrace using MACTRACE_HOME or HOME."""
    mactrace_home = os.environ.get('MACTRACE_HOME')
    if mactrace_home:
        return mactrace_home
    
    # Fall back to $HOME/.mactrace (not hardcoded ~)
    home = os.environ.get('HOME', os.path.expanduser('~'))
    return os.path.join(home, '.mactrace')


def filter_wrapper_processes(result: 'TraceResult', original_command: List[str], 
                              verbose: bool = False) -> 'TraceResult':
    """
    Filter out wrapper processes (sudo, sh, bash) and keep only the real target.
    
    When using -u/--user, the command is wrapped with 'sudo -u username -- cmd'.
    This function finds the first execve of the actual target command (not the wrappers)
    and filters events to only include that process and its descendants.
    
    Args:
        result: The full TraceResult with all events
        original_command: The user's original command (e.g., ['nmap', '-sV', 'target'])
        verbose: Print debug info
        
    Returns:
        Filtered TraceResult with only target command events
    """
    import os.path
    
    # Wrappers to skip when looking for the real target
    WRAPPER_BASENAMES = {'sudo', 'sh', 'bash', 'zsh', 'dash', 'ksh', 'env'}
    
    # What we're actually looking for (basename of the command)
    target_basename = os.path.basename(original_command[0]) if original_command else None
    if not target_basename:
        return result
    
    # Find the PID and timestamp of the real target by scanning execve events
    real_target_pid = None
    real_target_start_ts = None
    
    for event in result.events:
        syscall = event.get('syscall', '')
        if syscall not in ('execve', 'posix_spawn'):
            continue
        
        args = event.get('args', {})
        path = args.get('path', '')
        if not path:
            continue
        
        exec_basename = os.path.basename(path)
        
        # Skip wrapper processes
        if exec_basename in WRAPPER_BASENAMES:
            continue
        
        # Found the real target
        if exec_basename == target_basename or path.endswith('/' + target_basename):
            real_target_pid = event.get('pid')
            real_target_start_ts = event.get('timestamp_us', 0)
            if verbose:
                print(f"Found real target: {path} (pid={real_target_pid}, ts={real_target_start_ts})", 
                      file=sys.stderr)
            break
    
    if not real_target_pid:
        if verbose:
            print(f"Warning: Could not find execve of target '{target_basename}', keeping all events", 
                  file=sys.stderr)
            print(f"  (DTrace may have failed to capture execve paths - try --no-filter-wrapper)", 
                  file=sys.stderr)
        return result
    
    # Build set of PIDs to keep: real target + its descendants
    # process_tree is Dict[child_pid, parent_pid] - build reverse mapping
    children_of = {}  # parent_pid -> [child_pids]
    for child_pid, parent_pid in result.process_tree.items():
        if isinstance(child_pid, str):
            child_pid = int(child_pid)
        children_of.setdefault(parent_pid, []).append(child_pid)
    
    # Collect real target and all descendants
    keep_pids = {real_target_pid}
    queue = [real_target_pid]
    while queue:
        pid = queue.pop()
        for child in children_of.get(pid, []):
            if child not in keep_pids:
                keep_pids.add(child)
                queue.append(child)
    
    if verbose:
        print(f"Keeping {len(keep_pids)} PIDs: {sorted(keep_pids)}", file=sys.stderr)
    
    # Filter events
    filtered_events = [e for e in result.events if e.get('pid') in keep_pids]
    filtered_process_events = [e for e in result.process_events if e.get('pid') in keep_pids]
    
    # Filter process tree
    filtered_tree = {k: v for k, v in result.process_tree.items() if int(k) in keep_pids}
    
    # Rebuild summary
    summary = {}
    for event in filtered_events:
        syscall = event.get('syscall', 'unknown')
        summary[syscall] = summary.get(syscall, 0) + 1
    
    if verbose:
        orig_count = len(result.events)
        new_count = len(filtered_events)
        print(f"Filtered {orig_count - new_count} wrapper events ({orig_count} -> {new_count})", 
              file=sys.stderr)
    
    # Create new result with filtered data
    return TraceResult(
        command=original_command,
        start_time=result.start_time,
        end_time=result.end_time,
        duration_ms=result.duration_ms,
        target_pid=real_target_pid,  # Update to real target
        exit_code=result.exit_code,
        pids_traced=list(keep_pids),
        process_tree=filtered_tree,
        syscall_count=len(filtered_events),
        events=filtered_events,
        process_events=filtered_process_events,
        summary=summary,
        target_stdout=result.target_stdout,
        target_stderr=result.target_stderr
    )


def main():
    parser = argparse.ArgumentParser(
        description="mactrace - strace-like utility for macOS using DTrace",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Requires root privileges.

Trace a command:    sudo ./mactrace ls -la
Attach to a PID:   sudo ./mactrace -p 12345

Configuration (in priority order):
  1. Command-line flags
  2. Environment variables (need sudo -E to preserve)
  3. Config file: ~/.mactrace/config (works without sudo -E)
  4. Defaults

Config file format (processed top-to-bottom):
  # Comments start with #
  MACTRACE_HOME=~/.mactrace       # ~ = sudo caller's home
  MACTRACE_OUTPUT=~/traces
  MACTRACE_DB=$MACTRACE_HOME/db   # $VAR expands to config value

User selection:
  -u flag > MACTRACE_USER > SUDO_USER (auto) > root

Wrapper filtering (when -u or SUDO_USER is used):
  By default, syscalls from wrapper processes (sudo, sh, bash) are
  filtered out, keeping only the actual target command and its children.
  Use --no-filter-wrapper to disable and trace everything.

Path resolution for -o:
  /absolute/path  -> used as-is
  ./relative      -> used as-is
  filename.json   -> $MACTRACE_OUTPUT/filename.json

"""
    )
    parser.add_argument("-o", "--output", help="Output file (default: stdout). Relative paths use $MACTRACE_OUTPUT.")
    parser.add_argument("-u", "--user", 
                        help="Run traced program as this user (name or UID). Default: auto-detect from $SUDO_USER")
    parser.add_argument("-t", "--timeout", type=int, help="Timeout in seconds")
    parser.add_argument("-v", "--verbose", action="store_true", help="Verbose output to stderr")
    parser.add_argument("-jp", "--json-pretty", action="store_true", dest="json_pretty",
                        help="Pretty-print JSON output")
    parser.add_argument("-p", "--pid", type=int, default=None,
                        help="Attach to and trace an already-running process by PID (like strace -p)")
    parser.add_argument("-e", "--untraced", action="store_true", 
                        help="Show untraced syscalls summary to stderr")
    parser.add_argument("-d", "--capture-io", action="store_true",
                        help="Capture actual I/O data via tracemem (attached to syscall events as hex)")
    parser.add_argument("--io-size", type=int, default=1*1024*1024,
                        help="Max bytes to capture per I/O op (default: 1M, max ~4M due to dtrace limits)")
    parser.add_argument("--cache", type=str, default=None,
                        help="Copy local files up to SIZE to cache dir (e.g., 10M, 500k, 1G)")
    parser.add_argument("--strsize", type=int, default=16384,
                        help="DTrace strsize - max string size for paths etc (default: 16K)")
    parser.add_argument("--bufsize", type=str, default="256m",
                        help="DTrace bufsize - trace buffer size (default: 256m)")
    parser.add_argument("--dynvarsize", type=str, default="128m",
                        help="DTrace dynvarsize - dynamic variable space (default: 128m)")
    parser.add_argument("--no-filter-wrapper", action="store_true",
                        help="Don't filter out wrapper processes (sudo/sh/bash) when using -u")
    parser.add_argument("command", nargs=argparse.REMAINDER, help="Command to trace")
    
    args = parser.parse_args()
    
    if not args.command and args.pid is None:
        parser.print_help()
        sys.exit(1)
    
    if args.command and args.pid is not None:
        print("Error: Cannot use both -p PID and a command. Choose one.", file=sys.stderr)
        sys.exit(1)
        
    # Check if running as root
    if os.geteuid() != 0:
        print("Error: mactrace requires root privileges. Run with sudo.", file=sys.stderr)
        sys.exit(1)
    
    # Check output file doesn't exist (fail fast, before tracing)
    if args.output:
        output_path = resolve_path(args.output, 'MACTRACE_OUTPUT', check_exists=False)
        if os.path.exists(output_path):
            print(f"Error: Output file already exists: {output_path}", file=sys.stderr)
            print(f"Will not overwrite. Remove the file or choose a different output path.", file=sys.stderr)
            sys.exit(1)
    
    # Resolve user: -u/--user flag > MACTRACE_USER env var > SUDO_USER (auto-detect)
    user_spec = args.user or os.environ.get('MACTRACE_USER')
    run_as_user = None
    
    if user_spec:
        try:
            run_as_user = resolve_user(user_spec)
            if args.verbose:
                print(f"Will run traced program as user: {run_as_user[2]} (uid={run_as_user[0]}, gid={run_as_user[1]})", file=sys.stderr)
        except ValueError as e:
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)
    else:
        # Auto-detect: if running under sudo, use the original user
        sudo_user = os.environ.get('SUDO_USER')
        if sudo_user:
            try:
                run_as_user = resolve_user(sudo_user)
                if args.verbose:
                    print(f"Auto-detected sudo caller: {run_as_user[2]} (uid={run_as_user[0]}, gid={run_as_user[1]})", file=sys.stderr)
            except ValueError as e:
                # SUDO_USER exists but user doesn't - weird, but continue as root
                if args.verbose:
                    print(f"Warning: SUDO_USER={sudo_user} but user not found, running as root", file=sys.stderr)
    
    # Parse cache option
    cache_size = 0
    cache_dir = None
    if args.cache:
        try:
            cache_size = parse_size(args.cache)
            # Create cache directory next to output file or in temp
            if args.output:
                output_path = resolve_path(args.output, 'MACTRACE_OUTPUT', check_exists=False)
                cache_dir = output_path.rsplit('.', 1)[0] + '_cache'
            else:
                cache_dir = tempfile.mkdtemp(prefix='mactrace_cache_')
            dir_existed = os.path.exists(cache_dir)
            os.makedirs(cache_dir, exist_ok=True)
            # Chown cache dir to the user we'll run as
            if not dir_existed and run_as_user:
                try:
                    os.chown(cache_dir, run_as_user[0], run_as_user[1])
                except OSError:
                    pass
            if args.verbose:
                print(f"File cache enabled: up to {args.cache} per file → {cache_dir}/", file=sys.stderr)
        except ValueError as e:
            print(f"Error: Invalid --cache size '{args.cache}': {e}", file=sys.stderr)
            sys.exit(1)
        
    tracer = MacTrace(
        verbose=args.verbose,
        capture_io=args.capture_io,
        io_size=args.io_size,
        strsize=args.strsize,
        bufsize=args.bufsize,
        dynvarsize=args.dynvarsize,
        cache_size=cache_size,
        cache_dir=cache_dir
    )
    
    if args.pid is not None:
        # Attach to already-running process (like strace -p)
        result = tracer.trace_pid(args.pid, timeout=args.timeout)
    else:
        # Workaround for macOS 15+ dtrace bug: scripts with #!/bin/sh shebang
        # fail to execute properly when launched via dtrace -c. The script
        # exits immediately after sh execs to bash. Fix by explicitly running
        # such scripts via /bin/bash.
        command = args.command
        if command and os.path.isfile(command[0]):
            try:
                with open(command[0], 'rb') as f:
                    shebang = f.read(64)
                    # Check for #!/bin/sh (but not #!/bin/bash)
                    if shebang.startswith(b'#!') and b'/bin/sh' in shebang.split(b'\n')[0] and b'bash' not in shebang:
                        if args.verbose:
                            print(f"Detected #!/bin/sh script, wrapping with /bin/bash to work around macOS dtrace bug", file=sys.stderr)
                        command = ['/bin/bash'] + command
            except (IOError, OSError):
                pass  # Not readable, let it fail naturally
        
        result = tracer.trace(command, timeout=args.timeout, run_as_user=run_as_user)
        
        # Filter out wrapper processes (sudo, sh, bash) when using -u
        # This keeps only the real target command and its children
        if run_as_user and not args.no_filter_wrapper:
            result = filter_wrapper_processes(result, command, verbose=args.verbose)
    
    # Target stdout/stderr is already echoed to TTY in real-time during tracing
    # No need to print again here
    
    # Summary to stderr
    print(f"--- Trace summary ---", file=sys.stderr)
    print(f"PID: {result.target_pid}, Exit code: {result.exit_code}", file=sys.stderr)
    print(f"Syscalls: {result.syscall_count}, Processes: {len(result.pids_traced)}", file=sys.stderr)
    print(f"Duration: {result.duration_ms:.1f}ms", file=sys.stderr)
    
    # Show untraced syscalls if requested
    if args.untraced and tracer.all_syscall_counts:
        untraced = {}
        for syscall, count in tracer.all_syscall_counts.items():
            # Check if this syscall (or its _nocancel variant) is explicitly traced
            base_name = syscall.replace("_nocancel", "")
            if syscall not in tracer.TRACED_SYSCALLS and base_name not in tracer.TRACED_SYSCALLS:
                untraced[syscall] = count
        
        if untraced:
            print(f"--- Untraced syscalls ---", file=sys.stderr)
            for syscall, count in sorted(untraced.items(), key=lambda x: -x[1]):
                print(f"  {syscall}: {count}", file=sys.stderr)
        else:
            print(f"--- All syscalls traced ---", file=sys.stderr)
    
    # Wait for cache operations to complete
    if cache_dir and tracer._cached_files:
        success_count, error_count = tracer.wait_for_cache()
        if success_count > 0:
            print(f"Cached {success_count} file(s) to: {cache_dir}/", file=sys.stderr)
        if error_count > 0:
            print(f"Failed to cache {error_count} file(s)", file=sys.stderr)
    
    # Output JSON
    output_data = json.dumps(result.to_dict(), indent=2 if args.json_pretty else None)
    
    if args.output:
        # output_path was already resolved and validated at startup
        output_path = resolve_path(args.output, 'MACTRACE_OUTPUT', check_exists=False)
        
        # Ensure output directory exists
        output_dir = os.path.dirname(output_path)
        if output_dir:
            dir_created = not os.path.exists(output_dir)
            os.makedirs(output_dir, exist_ok=True)
            # Chown newly created directory to the user we ran as
            if dir_created and run_as_user:
                try:
                    os.chown(output_dir, run_as_user[0], run_as_user[1])
                except OSError:
                    pass  # Best effort
        
        with open(output_path, 'w') as f:
            f.write(output_data)
        
        # Chown output file to the user we ran as (not root)
        if run_as_user:
            try:
                os.chown(output_path, run_as_user[0], run_as_user[1])
            except OSError as e:
                if args.verbose:
                    print(f"Warning: Could not chown {output_path}: {e}", file=sys.stderr)
        
        print(f"Trace written to: {output_path}", file=sys.stderr)
    else:
        print(output_data)


if __name__ == "__main__":
    main()
