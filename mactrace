                sender, target, sig, ts = int(parts[1]), int(parts[2]), int(parts[3]), int(parts[4])
                self.process_events.append(ProcessEvent(
                    timestamp_us=ts - (self.start_timestamp or base_timestamp),
                    event_type="signal_send",
                    pid=sender,
                    tid=0,
                    details={"target_pid": target, "signal": sig, "signal_name": self._signal_name(sig)}
