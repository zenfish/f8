    # Syscalls we explicitly trace (for detecting untraced ones)
    TRACED_SYSCALLS = {
        # Process
        "fork", "execve", "posix_spawn", "exit", "wait4", "wait4_nocancel",
        # File ops
        "open", "open_nocancel", "openat", "openat_nocancel", "close", "close_nocancel",
        "read", "read_nocancel", "pread", "pread_nocancel",
