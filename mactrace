        "kill", "sigaction", "sigprocmask",
        "getpid", "getppid", "getuid", "geteuid", "getgid", "getegid",
    }
    
    def _signal_name(self, sig: int) -> str:
        """Convert signal number to name"""
        return self.SIGNAL_NAMES.get(sig, f"SIG{sig}")
        
    def _parse_open_flags(self, flags: int) -> str:
        """Convert open flags to string"""
        parts = []
        base = flags & 0x3
        if base == 0:
            parts.append("O_RDONLY")
        elif base == 1:
            parts.append("O_WRONLY")
        elif base == 2:
            parts.append("O_RDWR")
        
        if flags & 0x0200:
            parts.append("O_CREAT")
        if flags & 0x0400:
            parts.append("O_TRUNC")
        if flags & 0x0008:
            parts.append("O_APPEND")
        if flags & 0x0004:
            parts.append("O_NONBLOCK")
        if flags & 0x0100:
            parts.append("O_CLOEXEC")
            
        return "|".join(parts) if parts else f"0x{flags:x}"
    
    def _parse_line(self, line: str, base_timestamp: int) -> None:
        """Parse a single line of DTrace output"""
        line = line.strip()
        if not line or not line.startswith("MACTRACE_"):
            return
            
        parts = line.split(maxsplit=6)
        if len(parts) < 2:
            return
            
        event_type = parts[0]
        
        try:
            if event_type == "MACTRACE_START":
                # MACTRACE_START pid timestamp_us
                self.start_timestamp = int(parts[2]) if len(parts) > 2 else base_timestamp
                self.pids_traced.add(int(parts[1]))
                
            elif event_type == "MACTRACE_END":
                # MACTRACE_END timestamp_us
                self.end_timestamp = int(parts[1])
                
            elif event_type == "MACTRACE_ALLSYSCALL":
                # MACTRACE_ALLSYSCALL syscall_name count
                syscall_name = parts[1]
                if syscall_name != "__init__":  # Skip our initialization marker
                    count = int(parts[2])
                    self.all_syscall_counts[syscall_name] = count
                
            elif event_type == "MACTRACE_CHILD":
                # MACTRACE_CHILD pid ppid timestamp_us - first syscall from a child
                child_pid, ppid, ts = int(parts[1]), int(parts[2]), int(parts[3])
                self.pids_traced.add(child_pid)
                self.process_tree[child_pid] = ppid
                self.process_events.append(ProcessEvent(
                    timestamp_us=ts - (self.start_timestamp or base_timestamp),
                    event_type="child_detected",
                    pid=child_pid,
                    tid=0,
                    details={"parent_pid": ppid}
                ))
                
            elif event_type == "MACTRACE_FORK_CHILD":
                # MACTRACE_FORK_CHILD ppid child_pid tid timestamp_us
                ppid, child_pid, tid, ts = int(parts[1]), int(parts[2]), int(parts[3]), int(parts[4])
                self.pids_traced.add(child_pid)
                self.process_tree[child_pid] = ppid
                self.process_events.append(ProcessEvent(
                    timestamp_us=ts - (self.start_timestamp or base_timestamp),
                    event_type="fork",
                    pid=child_pid,
                    tid=tid,
                    details={"parent_pid": ppid}
                ))
                
            elif event_type == "MACTRACE_EXEC":
                # MACTRACE_EXEC pid ppid tid "path" timestamp_us
                pid, ppid, tid = int(parts[1]), int(parts[2]), int(parts[3])
                # Extract path from quotes
                rest = " ".join(parts[4:])
                match = re.match(r'"([^"]*)"(?:\s+(\d+))?', rest)
                if match:
                    path = match.group(1)
                    ts = int(match.group(2)) if match.group(2) else base_timestamp
                    self.pids_traced.add(pid)
                    if ppid > 0:
                        self.process_tree[pid] = ppid
                    self.process_events.append(ProcessEvent(
                        timestamp_us=ts - (self.start_timestamp or base_timestamp),
                        event_type="exec",
                        pid=pid,
                        tid=tid,
                        details={"path": path, "parent_pid": ppid}
                    ))
                    
            elif event_type == "MACTRACE_EXEC_ATTEMPT":
                # MACTRACE_EXEC_ATTEMPT pid ppid tid "path" timestamp_us
                pid, ppid, tid = int(parts[1]), int(parts[2]), int(parts[3])
                rest = " ".join(parts[4:])
                match = re.match(r'"([^"]*)"(?:\s+(\d+))?', rest)
                if match:
                    path = match.group(1)
                    ts = int(match.group(2)) if match.group(2) else base_timestamp
                    self.process_events.append(ProcessEvent(
                        timestamp_us=ts - (self.start_timestamp or base_timestamp),
                        event_type="exec_attempt",
                        pid=pid,
                        tid=tid,
                        details={"path": path, "parent_pid": ppid}
                    ))
                    
            elif event_type == "MACTRACE_EXEC_FAIL":
                # MACTRACE_EXEC_FAIL pid ppid tid errno timestamp_us
                pid, ppid, tid, err, ts = int(parts[1]), int(parts[2]), int(parts[3]), int(parts[4]), int(parts[5])
                self.process_events.append(ProcessEvent(
                    timestamp_us=ts - (self.start_timestamp or base_timestamp),
                    event_type="exec_fail",
                    pid=pid,
                    tid=tid,
                    details={"errno": err, "parent_pid": ppid}
                ))
                    
            elif event_type == "MACTRACE_EXIT":
                # MACTRACE_EXIT pid ppid exit_code timestamp_us
                pid, ppid, exit_code, ts = int(parts[1]), int(parts[2]), int(parts[3]), int(parts[4])
                self.process_events.append(ProcessEvent(
                    timestamp_us=ts - (self.start_timestamp or base_timestamp),
                    event_type="exit",
                    pid=pid,
                    tid=0,
                    details={"exit_code": exit_code, "parent_pid": ppid}
