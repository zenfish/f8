        }


class MacTrace:
    """Main tracer class"""
    
    def __init__(self, verbose: bool = False, capture_io: bool = False,
                 io_size: int = 1*1024*1024, strsize: int = 16384, bufsize: str = "256m", 
                 dynvarsize: str = "128m", cache_size: int = 0, cache_dir: str = None):
        self.verbose = verbose
        self.capture_io = capture_io
        self.io_size = io_size
        self.strsize = strsize
        # Warn about dtrace stack limits - large io_size can crash dtrace
        if io_size > 4*1024*1024:
            print(f"⚠️  --io-size={io_size} may crash dtrace (stack overflow). Try ≤4M.", file=sys.stderr)
        self.bufsize = bufsize
        self.dynvarsize = dynvarsize
        self.events: List[SyscallEvent] = []
        self.process_events: List[ProcessEvent] = []
        self.pids_traced: set = set()
        self.process_tree: Dict[int, int] = {}  # child_pid -> parent_pid
