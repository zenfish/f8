# Main
# ============================================================================

def main():
    parser = argparse.ArgumentParser(
        description='Analyze f8 JSON output',
        epilog='Reads JSON from f8 and produces analysis summary.'
    )
    parser.add_argument('file', help='f8 JSON file (use - for stdin)')
    parser.add_argument('-c', '--category', choices=CATEGORY_ORDER,
                        help='Filter to specific syscall category')
    parser.add_argument('--errors-only', action='store_true',
                        help='Only show errors')
    parser.add_argument('--hide-startup', action='store_true',
                        help='Hide startup/library files')
    parser.add_argument('--json', action='store_true',
                        help='Output JSON instead of text')
    parser.add_argument('--save-io', metavar='DIR',
                        help='Save I/O data to files in DIR (excludes startup libs/config)')
    parser.add_argument('--save-all-io', metavar='DIR',
                        help='Save ALL I/O data to files in DIR (includes startup files)')
    parser.add_argument('--hexdump', action='store_true',
                        help='Create .hexdump versions of I/O files (output of hexdump -C). '
                             'Note: the timeline server generates these on the fly from .bin '
                             'files, so this is only needed if you want them on disk')
    parser.add_argument('--render-terminal', action='store_true',
                        help='Create .rendered versions showing terminal output as user would see it')
    parser.add_argument('-v', '--verbose', action='store_true',
                        help='Show config resolution and processing details')
    args = parser.parse_args()
    
    # Resolve input file path using config
    input_file = resolve_input_path(args.file)
    if args.verbose:
        if input_file != args.file:
            print(f"Resolved {args.file} → {input_file}", file=sys.stderr)
    
    # Determine save_io directory
    save_io_dir = args.save_all_io or args.save_io
    save_all_io = args.save_all_io is not None
    
    # If save_io_dir is relative, use F8_OUTPUT
    if save_io_dir and not os.path.isabs(save_io_dir) and not save_io_dir.startswith('./'):
        output_dir = get_config_value('F8_OUTPUT')
        if output_dir:
            save_io_dir = os.path.join(output_dir, save_io_dir)
    
    analyzer = F8Analyzer(
        save_io_dir=save_io_dir,
        save_all_io=save_all_io,
        hexdump=args.hexdump,
        render_terminal_output=args.render_terminal,
    )
    
    try:
        analyzer.load(input_file)
    except FileNotFoundError:
        # Show the full path we tried if it differs from what user typed
        if input_file != args.file:
            print(f"Error: File not found: {input_file}", file=sys.stderr)
            print(f"  (resolved from: {args.file})", file=sys.stderr)
        else:
            print(f"Error: File not found: {args.file}", file=sys.stderr)
            # Hint about F8_OUTPUT if it's set
            output_dir = get_config_value('F8_OUTPUT')
            if output_dir:
                print(f"  (F8_OUTPUT={output_dir})", file=sys.stderr)
        sys.exit(1)
    except json.JSONDecodeError as e:
        print(f"Error: Invalid JSON in {input_file}: {e}", file=sys.stderr)
        sys.exit(1)
        
    if args.verbose:
        events = analyzer.trace_data.get('events', [])
        print(f"Loaded {len(events):,} events from {input_file}", file=sys.stderr)
        if save_io_dir:
            print(f"I/O output: {save_io_dir}", file=sys.stderr)
    
    analyzer.analyze()
    
    # Save I/O files if requested
    if save_io_dir:
        stats = analyzer.save_io_files()
        if stats.get('files_saved', 0) > 0:
            print(f"\n--- I/O Files Saved ---", file=sys.stderr)
            print(f"  Directory: {save_io_dir}", file=sys.stderr)
            print(f"  Files: {stats['files_saved']}", file=sys.stderr)
            print(f"  Total bytes: {format_bytes(stats['total_bytes'])}", file=sys.stderr)
            if stats.get('skipped_startup', 0) > 0:
                print(f"  Skipped startup I/O: {stats['skipped_startup']}", file=sys.stderr)
    
    if args.json:
        print(json.dumps(analyzer.to_json(), indent=2))
    else:
        analyzer.print_summary(
            category=args.category,
            errors_only=args.errors_only,
            hide_startup=args.hide_startup,
        )


if __name__ == '__main__':
    main()
