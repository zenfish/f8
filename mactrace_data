def cmd_db_list(args):
    """List DB traces only."""
    db = open_db(get_db_path(args.db))
    if not db:
        print("Error: Database not found.", file=sys.stderr)
        sys.exit(1)

    try:
        cursor = db.execute('''
            SELECT id, name, command, event_count, duration_ms, start_time, imported_at, json_file, io_dir
            FROM traces ORDER BY id
        ''')
        rows = cursor.fetchall()

        if not rows:
            if getattr(args, 'json', False):
                print("[]")
            else:
                print("No traces in database.")
            return

        if getattr(args, 'json', False):
            traces = [dict(row) for row in rows]
            print(json_module.dumps(traces, indent=2, default=str))
            return

        print(f"{'ID':>4}  {'Name':<20}  {'Events':>10}  {'Duration':>10}  {'Started':<20}  Command")
        print("-" * 100)

        for row in rows:
            name = row['name'] or '-'
            name = (name[:18] + '..') if len(name) > 20 else name
            cmd_short = row['command'] or '-'
            cmd_short = (cmd_short[:40] + '...') if len(cmd_short) > 43 else cmd_short
            duration = format_duration(row['duration_ms']) if row['duration_ms'] else '-'
            started = (row['start_time'][:19] if row['start_time'] else '-')
            events = row['event_count'] or 0
            print(f"{row['id']:>4}  {name:<20}  {events:>10,}  {duration:>10}  {started:<20}  {cmd_short}")

        print(f"\n{len(rows)} trace(s)")
    finally:
        db.close()


def cmd_db_info(args):
    """Show detailed info for a DB trace."""
    db = open_db(get_db_path(args.db))
    if not db:
        print("Error: Database not found.", file=sys.stderr)
        sys.exit(1)

    try:
        cursor = db.execute('''
            SELECT id, name, command, json_file, io_dir, target_pid, exit_code,
                   duration_ms, event_count, start_time, imported_at
            FROM traces WHERE id = ?
        ''', (args.trace_id,))

        row = cursor.fetchone()
        if not row:
            print(f"Error: No trace with ID {args.trace_id}", file=sys.stderr)
            sys.exit(1)

        print(f"Trace #{row['id']}: {row['name']}")
        print(f"  Command:     {row['command']}")
        print(f"  Target PID:  {row['target_pid']}")
        print(f"  Exit Code:   {row['exit_code']}")
        print(f"  Duration:    {format_duration(row['duration_ms']) if row['duration_ms'] else 'N/A'}")
        print(f"  Events:      {(row['event_count'] or 0):,}")
        print(f"  Started:     {row['start_time'] or 'N/A'}")
        print(f"  Imported:    {row['imported_at']}")
        print(f"  JSON File:   {row['json_file'] or 'N/A'}")
        print(f"  I/O Dir:     {row['io_dir'] or 'N/A'}")

        # Category breakdown
        cats = db.execute('''
            SELECT category, COUNT(*) as cnt FROM events WHERE trace_id = ?
            GROUP BY category ORDER BY cnt DESC
        ''', (row['id'],)).fetchall()
        if cats:
            print(f"\n  Categories:")
            for c in cats:
                print(f"    {c['category'] or 'other':<12} {c['cnt']:>8,}")

        # Top syscalls
        syscalls = db.execute('''
            SELECT syscall, COUNT(*) as cnt FROM events WHERE trace_id = ?
            GROUP BY syscall ORDER BY cnt DESC LIMIT 10
        ''', (row['id'],)).fetchall()
        if syscalls:
            print(f"\n  Top Syscalls:")
            for s in syscalls:
                print(f"    {s['syscall']:<24} {s['cnt']:>8,}")

        # Errors
        errs = db.execute('''
            SELECT errno_name, COUNT(*) as cnt FROM events WHERE trace_id = ? AND errno != 0
            GROUP BY errno_name ORDER BY cnt DESC LIMIT 5
        ''', (row['id'],)).fetchall()
        if errs:
            print(f"\n  Errors:")
            for e in errs:
                print(f"    {e['errno_name'] or 'unknown':<16} {e['cnt']:>8,}")
    finally:
        db.close()


