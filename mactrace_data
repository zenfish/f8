def cmd_list(args):
    """List all runs (unified view)."""
    runs = discover_runs(get_db_path(args.db), get_traces_dir(args.traces), skip_sizes=True)

    if not runs:
        print("No traces found (database or files).")
        return

    if getattr(args, 'json', False):
        # For JSON output, compute sizes
        runs = discover_runs(get_db_path(args.db), get_traces_dir(args.traces), skip_sizes=False)
        print(json_module.dumps(runs, indent=2, default=str))
        return

    # Calculate column widths dynamically
    max_name = max(len(r['name'][:25]) for r in runs)
    max_name = max(max_name, 4)  # min width for "Name"

    hdr = f"{'#':>4}  {'Name':<{max_name}}  {'Events':>10}  {'Duration':>10}  {'Date':<16}  {'DB':>2}  {'Files':>5}"
    print(hdr)
    print("-" * len(hdr))

    for r in runs:
        name = r['name'][:25]
        events = f"{r['events']:,}" if r['events'] else '-'
        duration = format_duration(r['duration_ms']) if r['duration_ms'] else '-'
        date = (r['date'][:16] if r['date'] else '-')
        db_mark = '\u2713' if r['has_db'] else '-'
        files_mark = '\u2713' if r['has_files'] else '-'

        print(f"{r['num']:>4}  {name:<{max_name}}  {events:>10}  {duration:>10}  {date:<16}  {db_mark:>2}  {files_mark:>5}")

    print(f"\n{len(runs)} run(s)")


def cmd_info(args):
    """Show details for a unified run."""
    runs = discover_runs(get_db_path(args.db), get_traces_dir(args.traces), skip_sizes=True)
    run = _find_run(runs, args.run_id)
    _fill_sizes(run)

    print(f"Run #{run['num']}: {run['name']}")
    print(f"  Command:     {run['command']}")
    print(f"  Events:      {run['events']:,}")
    if run['duration_ms']:
        print(f"  Duration:    {format_duration(run['duration_ms'])}")
    print(f"  Date:        {run['date'] or 'N/A'}")
    print()
    print(f"  Database:    {'yes (trace ID {})'.format(run['db_id']) if run['has_db'] else 'no'}")

    if run['json_file']:
        exists = os.path.exists(run['json_file'])
        size_str = format_size(run['json_size']) if exists and run['json_size'] else 'missing'
        print(f"  JSON file:   {run['json_file']} ({size_str})")
    else:
        print(f"  JSON file:   none")

    if run['io_dir']:
        exists = os.path.isdir(run['io_dir'])
        if exists:
            print(f"  I/O dir:     {run['io_dir']} ({run['io_count']} files, {format_size(run['io_size'])})")
        else:
            print(f"  I/O dir:     {run['io_dir']} (missing)")
    else:
        print(f"  I/O dir:     none")

    total = run['json_size'] + run['io_size']
    if total > 0:
        print(f"\n  Total on disk: {format_size(total)}")

    # If in DB, show category breakdown
    if run['has_db']:
        db = open_db(get_db_path(args.db))
        if db:
            try:
                cursor = db.execute('''
                    SELECT category, COUNT(*) as cnt
                    FROM events WHERE trace_id = ?
                    GROUP BY category ORDER BY cnt DESC
                ''', (run['db_id'],))
                cats = cursor.fetchall()
                if cats:
                    print(f"\n  Categories:")
                    for row in cats:
                        print(f"    {row['category'] or 'other':<12} {row['cnt']:>8,}")
            finally:
                db.close()


def cmd_delete(args):
    """Delete entire runs (DB + JSON + I/O files)."""
    db_path = get_db_path(args.db)
    traces_dir = get_traces_dir(args.traces)

    if args.all:
        _delete_all(db_path, traces_dir, args.force)
        return

    runs = discover_runs(db_path, traces_dir, skip_sizes=True)
    targets = []
    for rid in args.run_ids:
        t = _find_run(runs, rid)
        _fill_sizes(t)
        targets.append(t)

    if not targets:
        print("No runs to delete.")
        return

    # Show what will be deleted
    print("Runs to delete:")
    total_events = 0
    total_size = 0
    for r in targets:
        sz = r['json_size'] + r['io_size']
        parts = []
        if r['has_db']:
            parts.append(f"{r['events']:,} events in DB")
        if r['json_file'] and os.path.exists(r['json_file']):
            parts.append(f"JSON {format_size(r['json_size'])}")
        if r['io_dir'] and os.path.isdir(r['io_dir']):
            parts.append(f"I/O dir {r['io_count']} files")
        detail = ', '.join(parts) if parts else 'no data on disk'
        print(f"  #{r['num']}: {r['name']} ({detail})")
        total_events += r['events']
        total_size += sz

    if not args.force:
        msg = f"\nDelete {len(targets)} run(s)"
        parts = []
        if total_events:
            parts.append(f"{total_events:,} events")
        if total_size:
            parts.append(f"{format_size(total_size)} on disk")
        if parts:
            msg += f" ({', '.join(parts)})"
        msg += "? [y/N] "
        try:
            confirm = input(msg)
            if confirm.lower() not in ('y', 'yes'):
                print("Cancelled.")
                return
        except (EOFError, KeyboardInterrupt):
            print("\nCancelled.")
            return

    _perform_delete(db_path, targets)


def _delete_all(db_path, traces_dir, force):
    """Delete ALL data: database contents + all trace files."""
    runs = discover_runs(db_path, traces_dir, skip_sizes=True)

    if not runs:
        print("Nothing to delete.")
        return

    # Summarize (avoid per-dir sizing on slow volumes)
    db_count = sum(1 for r in runs if r['has_db'])
    file_count = sum(1 for r in runs if r['has_files'])
    total_events = sum(r['events'] for r in runs)
    db_size = os.path.getsize(db_path) if os.path.exists(db_path) else 0
    # Quick total: sum JSON file sizes (skip I/O dir sizing on slow volumes)
    total_size = 0
    for r in runs:
        if r['json_file'] and os.path.exists(r['json_file']):
            try:
                total_size += os.path.getsize(r['json_file'])
            except OSError:
                pass

    print("╔══════════════════════════════════════════════════╗")
    print("║         ⚠️  DELETE ALL MACTRACE DATA  ⚠️          ║")
    print("╠══════════════════════════════════════════════════╣")
    print(f"║  Runs:        {len(runs):<35}║")
    print(f"║  DB traces:   {db_count:<35}║")
    print(f"║  File sets:   {file_count:<35}║")
    print(f"║  Total events:{total_events:<35,}║")
    print(f"║  DB size:     {format_size(db_size):<35}║")
    print(f"║  Files size:  {format_size(total_size):<35}║")
    print(f"║  TOTAL:       {format_size(db_size + total_size):<35}║")
    print("╠══════════════════════════════════════════════════╣")
    print("║  This will permanently destroy ALL trace data.  ║")
    print("║  Database will be emptied. Files will be        ║")
    print("║  deleted from disk. This cannot be undone.      ║")
    print("╚══════════════════════════════════════════════════╝")

    if not force:
        try:
            confirm = input('\nType "delete everything" to confirm: ')
            if confirm.strip().lower() != 'delete everything':
                print("Cancelled.")
                return
        except (EOFError, KeyboardInterrupt):
            print("\nCancelled.")
            return

    _perform_delete(db_path, runs)

    # Vacuum the DB after bulk delete
    if os.path.exists(db_path):
        try:
            db = open_db(db_path)
            if db:
                before = os.path.getsize(db_path)
                db.execute('VACUUM')
                db.commit()
                db.close()
                after = os.path.getsize(db_path)
                print(f"Vacuumed database: {format_size(before)} → {format_size(after)}")
        except Exception as e:
            print(f"Warning: vacuum failed: {e}", file=sys.stderr)

    print("\nAll data deleted.")


def _perform_delete(db_path, runs):
    """Actually delete runs from DB and filesystem."""
    db = open_db(db_path, must_exist=False) if os.path.exists(db_path) else None

    for r in runs:
        parts_done = []

        # Delete from DB
        if r['has_db'] and db:
            db.execute('DELETE FROM traces WHERE id = ?', (r['db_id'],))
            parts_done.append(f"DB trace #{r['db_id']}")

        # Delete JSON file
        if r['json_file'] and os.path.exists(r['json_file']):
            try:
                os.unlink(r['json_file'])
                parts_done.append("JSON")
            except OSError as e:
                print(f"  Warning: could not delete {r['json_file']}: {e}", file=sys.stderr)

        # Delete I/O directory
        if r['io_dir'] and os.path.isdir(r['io_dir']):
            try:
                shutil.rmtree(r['io_dir'])
                parts_done.append(f"I/O dir ({r['io_count']} files)")
            except OSError as e:
                print(f"  Warning: could not delete {r['io_dir']}: {e}", file=sys.stderr)

        detail = ', '.join(parts_done) if parts_done else 'nothing to remove'
        print(f"  Deleted #{r['num']}: {r['name']} [{detail}]")

    if db:
        db.commit()
        db.close()


def _find_run(runs, run_id):
    """Find a run by its # number. Exits with error if not found."""
    for r in runs:
        if r['num'] == run_id:
            return r
    print(f"Error: No run #{run_id}. Use 'mactrace_data list' to see available runs.", file=sys.stderr)
    sys.exit(1)


