def cmd_files_list(args):
    """List JSON + I/O files on disk."""
    traces_dir = get_traces_dir(args.traces)

    if not traces_dir or not os.path.isdir(traces_dir):
        print(f"Traces directory not found: {traces_dir}")
        return

    entries = []
    try:
        items = sorted(os.listdir(traces_dir))
    except OSError as e:
        print(f"Error reading {traces_dir}: {e}", file=sys.stderr)
        return
    
    json_files = set()
    dirs = set()
    for item in items:
        if item.endswith('.json'):
            json_files.add(item[:-5])
        full = os.path.join(traces_dir, item)
        if os.path.isdir(full):
            dirs.add(item)

    for name in sorted(json_files):
        json_path = os.path.join(traces_dir, name + '.json')
        has_io = name in dirs
        # Get size without blocking — try quickly, fall back to 0
        try:
            json_size = os.path.getsize(json_path)
        except OSError:
            json_size = 0
        try:
            mtime = os.path.getmtime(json_path)
            date = datetime.fromtimestamp(mtime).strftime('%Y-%m-%d %H:%M')
        except OSError:
            date = '-'
        entries.append({
            'name': name,
            'json_file': json_path,
            'json_size': json_size,
            'has_io': has_io,
            'date': date,
        })

    if not entries:
        print("No trace files found.")
        return

    if getattr(args, 'json', False):
        print(json_module.dumps(entries, indent=2, default=str))
        return

    print(f"{'#':>4}  {'Name':<25}  {'JSON Size':>10}  {'I/O':>4}  {'Date':<16}")
    print("-" * 70)

    for i, e in enumerate(entries, 1):
        name = e['name'][:25]
        json_sz = format_size(e['json_size']) if e['json_size'] else '?'
        io_mark = '\u2713' if e.get('has_io') else '-'
        print(f"{i:>4}  {name:<25}  {json_sz:>10}  {io_mark:>4}  {e['date']:<16}")

    total_json = sum(e['json_size'] for e in entries)
    print(f"\n{len(entries)} file set(s), {format_size(total_json)} JSON total")


def cmd_files_info(args):
    """Show file details for a run."""
    runs = discover_runs(get_db_path(args.db), get_traces_dir(args.traces), skip_sizes=True)
    run = _find_run(runs, args.run_id)
    _fill_sizes(run)

    print(f"Run #{run['num']}: {run['name']}")

    if run['json_file']:
        exists = os.path.exists(run['json_file'])
        print(f"\n  JSON file: {run['json_file']}")
        if exists:
            print(f"    Size: {format_size(run['json_size'])}")
            st = os.stat(run['json_file'])
            print(f"    Modified: {datetime.fromtimestamp(st.st_mtime).strftime('%Y-%m-%d %H:%M:%S')}")
        else:
            print(f"    Status: MISSING")
    else:
        print(f"\n  JSON file: none")

    if run['io_dir']:
        exists = os.path.isdir(run['io_dir'])
        print(f"\n  I/O dir: {run['io_dir']}")
        if exists:
            print(f"    Files: {run['io_count']}")
            print(f"    Size: {format_size(run['io_size'])}")
            # Show first few files
            try:
                files = sorted(os.listdir(run['io_dir']))[:10]
                if files:
                    print(f"    Contents (first {min(10, len(files))}):")
                    for f in files:
                        fp = os.path.join(run['io_dir'], f)
                        sz = os.path.getsize(fp) if os.path.isfile(fp) else 0
                        print(f"      {f} ({format_size(sz)})")
                    total_files = len(os.listdir(run['io_dir']))
                    if total_files > 10:
                        print(f"      ... and {total_files - 10} more")
            except OSError:
                pass
        else:
            print(f"    Status: MISSING")
    else:
        print(f"\n  I/O dir: none")


def cmd_files_delete(args):
    """Delete files only, keep DB."""
    runs = discover_runs(get_db_path(args.db), get_traces_dir(args.traces), skip_sizes=True)
    targets = []
    for rid in args.run_ids:
        t = _find_run(runs, rid)
        _fill_sizes(t)
        targets.append(t)

    if not targets:
        print("No runs to delete files for.")
        return

    print("Files to delete (DB entries will be kept):")
    total_size = 0
    for r in targets:
        parts = []
        if r['json_file'] and os.path.exists(r['json_file']):
            parts.append(f"JSON {format_size(r['json_size'])}")
        if r['io_dir'] and os.path.isdir(r['io_dir']):
            parts.append(f"I/O dir {r['io_count']} files ({format_size(r['io_size'])})")
        if not parts:
            parts.append("no files on disk")
        print(f"  #{r['num']}: {r['name']} ({', '.join(parts)})")
        total_size += r['json_size'] + r['io_size']

    if not args.force:
        try:
            confirm = input(f"\nDelete files for {len(targets)} run(s) ({format_size(total_size)})? [y/N] ")
            if confirm.lower() not in ('y', 'yes'):
                print("Cancelled.")
                return
        except (EOFError, KeyboardInterrupt):
            print("\nCancelled.")
            return

    for r in targets:
        parts_done = []
        if r['json_file'] and os.path.exists(r['json_file']):
            try:
                os.unlink(r['json_file'])
                parts_done.append("JSON")
            except OSError as e:
                print(f"  Warning: could not delete {r['json_file']}: {e}", file=sys.stderr)
        if r['io_dir'] and os.path.isdir(r['io_dir']):
            try:
                shutil.rmtree(r['io_dir'])
                parts_done.append("I/O dir")
            except OSError as e:
                print(f"  Warning: could not delete {r['io_dir']}: {e}", file=sys.stderr)
        detail = ', '.join(parts_done) if parts_done else 'nothing to remove'
        print(f"  Deleted files for #{r['num']}: {r['name']} [{detail}]")


# =============================================================================
# Argument parsing
# =============================================================================

def main():
    parser = argparse.ArgumentParser(
        prog='mactrace_data',
        description='Unified data management for mactrace traces.',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog='''
Examples:
    mactrace_data list                     List all tracing runs
    mactrace_data info 3                   Details for run #3
    mactrace_data delete 1 2 3             Delete runs 1, 2, 3 (DB + files)
    mactrace_data delete --all             Delete everything (prompts)
    mactrace_data delete --all --force     Delete everything, no prompt

    mactrace_data db list                  List DB traces only
    mactrace_data db info 5               DB trace #5 details
    mactrace_data db delete 5 -f           Remove from DB, no prompt
    mactrace_data db vacuum                Compact the database
    mactrace_data db stats                 Database statistics

    mactrace_data files list               List JSON + I/O files on disk
    mactrace_data files info 3             File details for run #3
    mactrace_data files delete 3           Delete files only, keep DB
'''
    )
    parser.add_argument('-d', '--db', help='Database file path')
    parser.add_argument('-t', '--traces', help='Traces directory path')
    parser.add_argument('-f', '--force', action='store_true', help="Don't prompt for confirmation")
    parser.add_argument('-v', '--verbose', action='store_true', help='Show config resolution details')

    subparsers = parser.add_subparsers(dest='command', help='Command')

    # --- Top-level commands ---

    # list
    list_p = subparsers.add_parser('list', aliases=['ls'], help='List all runs (unified)')
    list_p.add_argument('-j', '--json', action='store_true', help='Output as JSON')

    # info
    info_p = subparsers.add_parser('info', aliases=['show'], help='Show run details')
    info_p.add_argument('run_id', type=int, help='Run number (from list)')

    # delete
    del_p = subparsers.add_parser('delete', aliases=['rm', 'del'], help='Delete run(s)')
    del_p.add_argument('run_ids', type=int, nargs='*', help='Run number(s) to delete')
    del_p.add_argument('--all', action='store_true', help='Delete ALL data')

    # --- db subcommand ---
    db_p = subparsers.add_parser('db', help='Database-only operations')
    db_sub = db_p.add_subparsers(dest='db_command', help='DB command')

    db_list_p = db_sub.add_parser('list', aliases=['ls'], help='List DB traces')
    db_list_p.add_argument('-j', '--json', action='store_true', help='Output as JSON')

    db_info_p = db_sub.add_parser('info', aliases=['show'], help='Show DB trace details')
    db_info_p.add_argument('trace_id', type=int, help='DB trace ID')

    db_del_p = db_sub.add_parser('delete', aliases=['rm', 'del'], help='Delete from DB only')
    db_del_p.add_argument('trace_ids', type=int, nargs='+', help='DB trace ID(s)')

    db_sub.add_parser('vacuum', help='Compact the database')
    db_sub.add_parser('stats', help='Show database statistics')

    # --- files subcommand ---
    files_p = subparsers.add_parser('files', help='File-only operations')
    files_sub = files_p.add_subparsers(dest='files_command', help='Files command')

    files_list_p = files_sub.add_parser('list', aliases=['ls'], help='List trace files')
    files_list_p.add_argument('-j', '--json', action='store_true', help='Output as JSON')

    files_info_p = files_sub.add_parser('info', aliases=['show'], help='Show file details')
    files_info_p.add_argument('run_id', type=int, help='Run number (from list)')

    files_del_p = files_sub.add_parser('delete', aliases=['rm', 'del'], help='Delete files only')
    files_del_p.add_argument('run_ids', type=int, nargs='+', help='Run number(s)')

    args = parser.parse_args()

    if args.verbose:
        db_path = get_db_path(args.db)
        traces_dir = get_traces_dir(args.traces)
        config = get_mactrace_config()
        print(f"Database:   {db_path}", file=sys.stderr)
        print(f"Traces dir: {traces_dir}", file=sys.stderr)
        if config:
            print(f"Config:     {', '.join(f'{k}={v}' for k, v in config.items())}", file=sys.stderr)

    if not args.command:
        parser.print_help()
        sys.exit(1)

    # Route to handler
    if args.command in ('list', 'ls'):
        cmd_list(args)
    elif args.command in ('info', 'show'):
        cmd_info(args)
    elif args.command in ('delete', 'rm', 'del'):
        if not args.all and not args.run_ids:
            print("Error: specify run number(s) or --all", file=sys.stderr)
            sys.exit(1)
        cmd_delete(args)
    elif args.command == 'db':
        if not getattr(args, 'db_command', None):
            db_p.print_help()
            sys.exit(1)
        if args.db_command in ('list', 'ls'):
            cmd_db_list(args)
        elif args.db_command in ('info', 'show'):
            cmd_db_info(args)
        elif args.db_command in ('delete', 'rm', 'del'):
            cmd_db_delete(args)
        elif args.db_command == 'vacuum':
            cmd_db_vacuum(args)
        elif args.db_command == 'stats':
            cmd_db_stats(args)
    elif args.command == 'files':
        if not getattr(args, 'files_command', None):
            files_p.print_help()
            sys.exit(1)
        if args.files_command in ('list', 'ls'):
            cmd_files_list(args)
        elif args.files_command in ('info', 'show'):
            cmd_files_info(args)
        elif args.files_command in ('delete', 'rm', 'del'):
            cmd_files_delete(args)


if __name__ == '__main__':
    main()
