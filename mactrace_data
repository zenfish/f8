#!/usr/bin/env python3
"""
mactrace_data - Unified data management for mactrace.

Manages trace data across the database, JSON files, and I/O binary files.

Usage:
    mactrace_data list                     List all runs (unified: DB + files)
    mactrace_data info <N>                 Show details for run #N
    mactrace_data delete <N>...            Delete run(s): DB + JSON + I/O files
    mactrace_data delete --all             Delete everything (prompts first)
    mactrace_data delete --all --force     Delete everything without prompting

    mactrace_data db list [-j]             List DB traces
    mactrace_data db info <id>             Show DB trace details
    mactrace_data db delete <id>...        Delete from DB only
    mactrace_data db vacuum                Compact the database
    mactrace_data db stats                 Show database statistics

    mactrace_data files list [-j]          List JSON + I/O files on disk
    mactrace_data files info <N>           Show file details for run #N
    mactrace_data files delete <N>...      Delete files only, keep DB

Options:
    -d, --db PATH      Database file (default: from config or ./mactrace.db)
    -t, --traces PATH  Traces directory (default: from MACTRACE_OUTPUT config)
    -f, --force        Don't prompt for confirmation on delete
    -j, --json         Output as JSON
    -v, --verbose      Show config resolution details
    -h, --help         Show this help
"""

import argparse
import glob
import json as json_module
import os
import shutil
import sqlite3
import sys
sys.dont_write_bytecode = True
from datetime import datetime

# Shared utilities
from mactrace_lib import (
    get_mactrace_config, get_config_value, resolve_input_path,
    format_bytes as format_size, format_duration,
)


# =============================================================================
# Configuration
# =============================================================================

def get_db_path(args_db=None):
    """Determine database path from args, config, or default."""
    if args_db:
        return args_db
    config = get_mactrace_config()
    if 'MACTRACE_DB' in config:
        return config['MACTRACE_DB']
    if 'MACTRACE_DB' in os.environ:
        return os.environ['MACTRACE_DB']
    return 'mactrace.db'


def get_traces_dir(args_traces=None):
    """Determine traces directory from args, config, or default."""
    if args_traces:
        return args_traces
    config = get_mactrace_config()
    if 'MACTRACE_OUTPUT' in config:
        return config['MACTRACE_OUTPUT']
    if 'MACTRACE_OUTPUT' in os.environ:
        return os.environ['MACTRACE_OUTPUT']
    return './traces'


def open_db(db_path, must_exist=True):
    """Open database, return connection or None if it doesn't exist."""
    if must_exist and not os.path.exists(db_path):
        return None
    db = sqlite3.connect(db_path)
    db.row_factory = sqlite3.Row
    db.execute('PRAGMA foreign_keys = ON')
    return db


# =============================================================================
# Unified run discovery
# =============================================================================

def discover_runs(db_path, traces_dir, skip_sizes=False):
    """
    Build a unified list of tracing runs from DB and filesystem.

    Each run is a dict with:
        num:         1-based index for user reference
        name:        trace name (from DB or filename)
        command:     full command (from DB)
        events:      event count (from DB, 0 if not imported)
        duration_ms: trace duration (from DB)
        date:        start time or file modification time
        db_id:       DB trace ID (None if file-only)
        json_file:   path to JSON file (None if DB-only)
        io_dir:      path to I/O directory (None if none)
        has_db:      bool
        has_files:   bool (JSON or io_dir exists on disk)
        json_size:   JSON file size in bytes (0 if absent)
        io_size:     total I/O dir size in bytes (0 if absent)
        io_count:    number of files in I/O dir (0 if absent)
    """
    runs = []
    seen_json = set()  # track JSON files we've accounted for
    seen_io = set()    # track I/O dirs we've accounted for

    # --- Phase 1: DB traces ---
    db = open_db(db_path, must_exist=True)
    if db:
        try:
            cursor = db.execute('''
                SELECT id, name, command, event_count, duration_ms, start_time,
                       imported_at, json_file, io_dir
                FROM traces ORDER BY id
            ''')
            for row in cursor.fetchall():
                json_file = row['json_file']
                io_dir = row['io_dir']
                json_exists = json_file and os.path.exists(json_file)
                io_exists = io_dir and os.path.isdir(io_dir)

                json_sz = os.path.getsize(json_file) if json_exists and not skip_sizes else 0
                io_sz, io_cnt = _dir_size(io_dir) if io_exists and not skip_sizes else (0, 0)

                runs.append({
                    'name': row['name'] or '-',
                    'command': row['command'] or '-',
                    'events': row['event_count'] or 0,
                    'duration_ms': row['duration_ms'],
                    'date': row['start_time'] or row['imported_at'] or '',
                    'db_id': row['id'],
                    'json_file': json_file if json_exists else json_file,
                    'io_dir': io_dir if io_exists else io_dir,
                    'has_db': True,
                    'has_files': json_exists or io_exists,
                    'json_size': json_sz,
                    'io_size': io_sz,
                    'io_count': io_cnt,
                })
                if json_file:
                    seen_json.add(os.path.realpath(json_file) if os.path.exists(json_file) else json_file)
                if io_dir:
                    seen_io.add(os.path.realpath(io_dir) if os.path.exists(io_dir) else io_dir)
        finally:
            db.close()

    # --- Phase 2: orphan files in traces directory ---
    if traces_dir and os.path.isdir(traces_dir):
        for entry in sorted(os.listdir(traces_dir)):
            full = os.path.join(traces_dir, entry)

            if entry.endswith('.json') and os.path.isfile(full):
                real = os.path.realpath(full)
                if real in seen_json:
                    continue
                seen_json.add(real)

                name = entry[:-5]  # strip .json
                st = os.stat(full)
                # Check for matching I/O directory
                io_dir_candidate = os.path.join(traces_dir, name)
                io_exists = os.path.isdir(io_dir_candidate)
                io_real = os.path.realpath(io_dir_candidate) if io_exists else None
                io_sz, io_cnt = _dir_size(io_dir_candidate) if io_exists and not skip_sizes else (0, 0)

                runs.append({
                    'name': name,
                    'command': '-',
                    'events': 0,
                    'duration_ms': None,
                    'date': datetime.fromtimestamp(st.st_mtime).strftime('%Y-%m-%dT%H:%M:%S'),
                    'db_id': None,
                    'json_file': full,
                    'io_dir': io_dir_candidate if io_exists else None,
                    'has_db': False,
                    'has_files': True,
                    'json_size': st.st_size if not skip_sizes else 0,
                    'io_size': io_sz,
                    'io_count': io_cnt,
                })
                if io_real:
                    seen_io.add(io_real)

            elif os.path.isdir(full):
                real = os.path.realpath(full)
                if real in seen_io:
                    continue
                # Orphan I/O directory with no matching JSON or DB entry
                json_candidate = full + '.json'
                if os.path.exists(json_candidate):
                    continue  # will be picked up by the .json branch
                seen_io.add(real)
                io_sz, io_cnt = _dir_size(full) if not skip_sizes else (1, 1)  # assume non-empty if not sizing

                st = os.stat(full)
                runs.append({
                    'name': entry,
                    'command': '-',
                    'events': 0,
                    'duration_ms': None,
                    'date': datetime.fromtimestamp(st.st_mtime).strftime('%Y-%m-%dT%H:%M:%S'),
                    'db_id': None,
                    'json_file': None,
                    'io_dir': full,
                    'has_db': False,
                    'has_files': True,
                    'json_size': 0,
                    'io_size': io_sz,
                    'io_count': io_cnt,
                })

    # Assign 1-based run numbers
    for i, run in enumerate(runs):
        run['num'] = i + 1

    return runs


def _dir_size(path, quick=True):
    """Return (total_bytes, file_count) for a directory.
    
    quick=True uses st_nlink (fast but approximate file count) and
    du -sk (fast kernel-level size). Falls back to scandir on error.
    """
    if quick:
        try:
            import subprocess
            # st_nlink - 2 gives approximate file count (. and .. don't count)
            st = os.stat(path)
            count = max(0, st.st_nlink - 2)
            # du -sk is fast even for huge dirs (kernel-level)
            result = subprocess.run(
                ['du', '-sk', path],
                capture_output=True, text=True, timeout=5
            )
            if result.returncode == 0:
                total = int(result.stdout.split()[0]) * 1024
                return total, count
        except (OSError, subprocess.TimeoutExpired, ValueError, IndexError):
            pass
    # Fallback: walk directory (slow for large dirs)
    total = 0
    count = 0
    try:
        for entry in os.scandir(path):
            if entry.is_file(follow_symlinks=False):
                total += entry.stat().st_size
                count += 1
    except (OSError, PermissionError):
        pass
    return total, count


def _fill_sizes(run):
    """Compute actual sizes for a single run (on demand)."""
    if run['json_file'] and os.path.exists(run['json_file']):
        run['json_size'] = os.path.getsize(run['json_file'])
    if run['io_dir'] and os.path.isdir(run['io_dir']):
        run['io_size'], run['io_count'] = _dir_size(run['io_dir'])

