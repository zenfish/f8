            print(f"Warning: Trace ID(s) not found: {', '.join(map(str, missing))}", file=sys.stderr)

        if not found:
            print("No traces to delete.")
            return

        print("DB traces to delete:")
        total_events = 0
        for row in found:
            print(f"  #{row['id']}: {row['name']} ({(row['event_count'] or 0):,} events)")
            total_events += row['event_count'] or 0

        if not args.force:
            try:
                confirm = input(f"\nDelete {len(found)} trace(s) with {total_events:,} events from DB? [y/N] ")
                if confirm.lower() not in ('y', 'yes'):
                    print("Cancelled.")
                    return
            except (EOFError, KeyboardInterrupt):
                print("\nCancelled.")
                return

        for row in found:
            db.execute('DELETE FROM traces WHERE id = ?', (row['id'],))
            print(f"Deleted trace #{row['id']}: {row['name']}")

        db.commit()
        print(f"\nDeleted {len(found)} trace(s) from database.")
    finally:
        db.close()


def cmd_db_vacuum(args):
    """Compact the database."""
    db_path = get_db_path(args.db)
    db = open_db(db_path)
    if not db:
        print("Error: Database not found.", file=sys.stderr)
        sys.exit(1)

    try:
        size_before = os.path.getsize(db_path)
        print(f"Vacuuming {db_path}...")
        db.execute('VACUUM')
        db.commit()
        size_after = os.path.getsize(db_path)
        saved = size_before - size_after
        print(f"Done. {format_size(size_before)} → {format_size(size_after)} (saved {format_size(saved)})")
    finally:
        db.close()


def cmd_db_stats(args):
    """Show database statistics."""
    db_path = get_db_path(args.db)
    db = open_db(db_path)
    if not db:
        print("Error: Database not found.", file=sys.stderr)
        sys.exit(1)

    try:
        size = os.path.getsize(db_path) if os.path.exists(db_path) else 0
        print(f"Database: {db_path}")
        print(f"Size:     {format_size(size)}")

        cursor = db.execute('SELECT COUNT(*), SUM(event_count), SUM(duration_ms) FROM traces')
        row = cursor.fetchone()
        trace_count = row[0] or 0
        total_events = row[1] or 0
        total_duration = row[2]

        print(f"\nTraces:   {trace_count}")
        print(f"Events:   {total_events:,}")
        if total_duration:
            print(f"Total traced time: {format_duration(total_duration)}")

        cats = db.execute('''
            SELECT category, COUNT(*) as cnt FROM events
            GROUP BY category ORDER BY cnt DESC
        ''').fetchall()
        if cats:
            print(f"\nEvents by category:")
            for c in cats:
                print(f"  {c['category'] or 'other':<12} {c['cnt']:>10,}")
    finally:
        db.close()


